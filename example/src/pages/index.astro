---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
	<main class="main">
		<section class="card">
			<h2>Theme <code>$store.theme</code></h2>
			<p>
				Mode: <strong x-text="$store.theme.mode"></strong> → resolved:
				<strong x-text="$store.theme.resolved"></strong>
			</p>
			<div class="btn-group">
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isLight }"
					@click="$store.theme.set('light')"
				>
					Light
				</button>
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isDark }"
					@click="$store.theme.set('dark')"
				>
					Dark
				</button>
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isSystem }"
					@click="$store.theme.set('system')"
				>
					System
				</button>
				<button type="button" @click="$store.theme.cycle()">Cycle</button>
			</div>
		</section>

		<section class="card">
			<h2>Screen <code>$store.device</code></h2>
			<p>
				Type: <strong x-text="$store.device.type"></strong> · Width:
				<strong x-text="$store.device.width"></strong>px
			</p>
			<div class="badges">
				<span class="badge" x-bind:class="{ on: $store.device.isMobile }">Mobile</span>
				<span class="badge" x-bind:class="{ on: $store.device.isTablet }">Tablet</span>
				<span class="badge" x-bind:class="{ on: $store.device.isDesktop }">Desktop</span>
			</div>
		</section>

		<section class="card">
			<h2>Scroll <code>$store.scroll</code></h2>
			<ul class="list">
				<li>Y: <strong x-text="Math.round($store.scroll.y)"></strong>px</li>
				<li>Direction: <strong x-text="$store.scroll.direction || '—'"></strong></li>
				<li>Progress: <strong x-text="Math.round($store.scroll.progress)"></strong>%</li>
				<li>Locked: <strong x-text="$store.scroll.isLocked"></strong></li>
			</ul>
			<div class="btn-group">
				<button type="button" @click="$store.scroll.toggleLock()">
					<span x-text="$store.scroll.isLocked ? 'Unlock scroll' : 'Lock scroll'"></span>
				</button>
				<button type="button" x-show="$store.scroll.showToTop" x-cloak @click="$store.scroll.toTop()">
					Back to top
				</button>
			</div>
		</section>

		<section class="card">
			<h2>Network <code>$network</code></h2>
			<p
				class="status"
				x-bind:class="$network.isOnline ? 'status--ok' : 'status--warn'"
				x-text="$network.isOnline ? 'Online' : 'Offline'"
			></p>
			<div class="btn-group">
				<button type="button" x-bind:disabled="!$network.isOnline">Save (requires connection)</button>
			</div>
		</section>

		<section class="card">
			<h2>Visibility <code>$visibility</code></h2>
			<p
				class="status"
				x-bind:class="$visibility.isVisible ? 'status--ok' : 'status--warn'"
				x-text="$visibility.isVisible ? 'Tab visible' : 'Tab hidden'"
			></p>
			<ul class="list">
				<li>State: <strong x-text="$visibility.state"></strong></li>
			</ul>
			<p class="hint">Switch to another tab to see the state update.</p>
		</section>

		<section class="card">
			<h2>Battery <code>$battery</code></h2>
			<template x-if="$battery.isAvailable">
				<div>
					<div class="battery-widget" aria-hidden="true">
						<div class="battery-shell">
							<div
								class="battery-fill"
								x-bind:class="{
									'battery-fill--low': $battery.level < 0.2 && !$battery.isCharging,
									'battery-fill--charging': $battery.isCharging,
								}"
								x-bind:style="'width: ' + Math.round($battery.level * 100) + '%'"
							></div>
						</div>
						<span class="battery-label" x-text="Math.round($battery.level * 100) + '%'"></span>
					</div>
					<p
						class="status"
						x-bind:class="$battery.isCharging ? 'status--ok' : 'status--warn'"
						x-text="$battery.isCharging ? 'Charging' : 'On battery'"
					></p>
					<ul class="list">
						<li x-show="$battery.chargingTime !== null">
							Time to full:
							<strong x-text="Math.round($battery.chargingTime / 60) + ' min'"></strong>
						</li>
						<li x-show="$battery.dischargingTime !== null">
							Time to empty:
							<strong x-text="Math.round($battery.dischargingTime / 60) + ' min'"></strong>
						</li>
					</ul>
					<p
						class="hint hint--error"
						x-show="$battery.level < 0.2 && !$battery.isCharging"
						x-cloak
					>
						Low battery — consider plugging in your device.
					</p>
				</div>
			</template>
			<p class="hint" x-show="!$battery.isAvailable" x-cloak>
				Battery status is not available on this device or browser.
			</p>
		</section>

		<section class="card">
			<h2>Clipboard <code>$clipboard</code></h2>
			<button
				type="button"
				@click="await $clipboard('Hello from Alpine!'); copied = true; setTimeout(() => copied = false, 2000)"
			>
				Copy text
			</button>
			<p class="hint" x-show="copied" x-cloak x-transition>Copied to clipboard!</p>
		</section>

		<section class="card">
			<h2>Export <code>$export</code></h2>
			<p class="hint" x-show="!$export.isSupported()" x-cloak>
				Programmatic file exports are not available in this environment.
			</p>
			<template x-if="$export.isSupported()">
				<div>
					<div class="btn-group">
						<button
							type="button"
							@click="exportedText = await $export('Hello from Alpine!', 'hello.txt')"
						>
							Export text
						</button>
						<button
							type="button"
							@click="exportedJson = await $export(
								JSON.stringify({ plugin: 'export', savedAt: Date.now() }, null, 2),
								{ filename: 'export.json', mimeType: 'application/json' }
							)"
						>
							Export JSON
						</button>
					</div>
					<p class="hint" x-show="exportedText === true" x-cloak x-transition>Text export started.</p>
					<p class="hint" x-show="exportedJson === true" x-cloak x-transition>JSON export started.</p>
				</div>
			</template>
		</section>

		<section class="card">
			<h2>Share <code>$share</code></h2>
			<p class="hint" x-show="!$share.isSupported()" x-cloak>
				Web Share API is not available in this browser.
			</p>
			<template x-if="$share.isSupported()">
				<div>
					<button
						type="button"
						@click="shared = await $share({
							title: document.title,
							text: 'Check out this Alpine.js plugin demo',
							url: window.location.href
						})"
					>
						Share page
					</button>
					<p class="hint" x-show="shared === true" x-cloak x-transition>Thanks for sharing!</p>
					<p class="hint" x-show="shared === false" x-cloak x-transition>Share cancelled.</p>
				</div>
			</template>
		</section>

		<section class="card">
			<h2>Geo <code>$store.geo</code></h2>
			<p class="hint" x-show="!$store.geo.isSupported" x-cloak>
				Geolocation is not available in this browser.
			</p>
			<template x-if="$store.geo.isSupported">
				<div>
					<div class="btn-group">
						<button
							type="button"
							@click="$store.geo.request({ enableHighAccuracy: true })"
							x-bind:disabled="$store.geo.isLoading"
						>
							<span x-text="$store.geo.isLoading ? 'Locating…' : 'Get location'"></span>
						</button>
						<button
							type="button"
							x-show="!$store.geo.isWatching"
							x-cloak
							@click="$store.geo.watch()"
						>
							Start tracking
						</button>
						<button
							type="button"
							x-show="$store.geo.isWatching"
							x-cloak
							@click="$store.geo.unwatch()"
						>
							Stop tracking
						</button>
						<button type="button" @click="$store.geo.reset()">Reset</button>
					</div>
					<p x-show="$store.geo.hasPosition" x-cloak>
						Lat: <strong x-text="$store.geo.latitude?.toFixed(4)"></strong>,
						Lng: <strong x-text="$store.geo.longitude?.toFixed(4)"></strong>
						(±<strong x-text="Math.round($store.geo.accuracy ?? 0)"></strong> m)
					</p>
					<p class="hint hint--error" x-show="$store.geo.hasError" x-cloak x-text="$store.geo.error"></p>
				</div>
			</template>
		</section>

		<section class="card">
			<h2>Touch <code>$touch</code></h2>
			<ul class="list">
				<li>Touch: <strong x-text="$touch.isTouch"></strong></li>
				<li>Coarse pointer: <strong x-text="$touch.isCoarse"></strong></li>
				<li>Hover: <strong x-text="$touch.canHover"></strong></li>
				<li>Max touch points: <strong x-text="$touch.maxTouchPoints"></strong></li>
			</ul>
		</section>

		<section class="card">
			<h2>Platform <code>$platform</code></h2>
			<p>
				Detected OS: <strong x-text="$platform.name"></strong>
			</p>
			<div class="badges">
				<span class="badge" x-bind:class="{ on: $platform.isMac }">macOS</span>
				<span class="badge" x-bind:class="{ on: $platform.isWindows }">Windows</span>
				<span class="badge" x-bind:class="{ on: $platform.isLinux }">Linux</span>
				<span class="badge" x-bind:class="{ on: $platform.isIos }">iOS</span>
				<span class="badge" x-bind:class="{ on: $platform.isAndroid }">Android</span>
				<span class="badge" x-bind:class="{ on: $platform.isChromeos }">ChromeOS</span>
			</div>
			<p class="hint" x-show="$platform.isMac" x-cloak>Use <kbd>⌘</kbd> + <kbd>C</kbd> to copy.</p>
			<p class="hint" x-show="$platform.isWindows || $platform.isLinux" x-cloak>
				Use <kbd>Ctrl</kbd> + <kbd>C</kbd> to copy.
			</p>
			<p class="hint" x-show="$platform.isIos || $platform.isAndroid" x-cloak>
				Touch-optimized shortcuts may differ from desktop.
			</p>
		</section>

		<section class="card">
			<h2>Notify <code>$notify</code></h2>
			<ul class="list">
				<li>Supported: <strong x-text="$notify.isSupported()"></strong></li>
				<li>Permission: <strong x-text="$notify.permission()"></strong></li>
			</ul>
			<p class="hint hint--error" x-show="$notify.requiresHomeScreenInstall()" x-cloak>
				On iPhone and iPad, add this site to your Home Screen and open it from there to enable notifications.
			</p>
			<div class="btn-group">
				<button
					type="button"
					x-show="$notify.isSupported() && $notify.permission() === 'default'"
					x-cloak
					@click="await $notify.requestPermission()"
				>
					Request permission
				</button>
				<button
					type="button"
					x-show="$notify.isSupported() && $notify.permission() === 'granted'"
					x-cloak
					@click="await $notify.sendAsync('Task complete', { body: 'Plugins are working correctly.' })"
				>
					Send notification
				</button>
				<button
					type="button"
					x-show="$notify.isSupported()"
					x-cloak
					@click="await $notify.sendIfPermittedAsync('Silent notification')"
				>
					sendIfPermitted
				</button>
			</div>
			<p class="hint hint--error" x-show="$notify.isSupported() && $notify.permission() === 'denied'" x-cloak>
				Permission denied — enable notifications in your browser settings.
			</p>
		</section>
	</main>

	<footer class="footer">
		<p>
			<a href="https://github.com/ailuracode/alpine" target="_blank" rel="noreferrer">Source</a>
			·
			<a href="https://www.npmjs.com/~siddharthagf" target="_blank" rel="noreferrer">npm</a>
		</p>
	</footer>
</BaseLayout>
