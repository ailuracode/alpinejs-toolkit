---
import PokeapiQueryDemo from "../components/PokeapiQueryDemo.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
	<main
		class="px-6 py-4 grid gap-4 pb-16 transition-[margin-left] duration-300"
		x-bind:class="$store.device?.is('desktop') ? ($store.sidebar.collapsed ? 'ml-16' : 'ml-64') : 'max-w-3xl mx-auto'"
	>
		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Theme <code class="text-base-content/60 font-normal">$store.theme</code></h2>
				<p>
					Mode: <strong x-text="$store.theme.mode"></strong> → resolved:
					<strong x-text="$store.theme.resolved"></strong>
				</p>
				<div class="flex flex-wrap gap-2 mt-3">
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-bind:class="{ 'btn-primary': $store.theme.isLight }"
						@click="$store.theme.set('light')"
					>
						Light
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-bind:class="{ 'btn-primary': $store.theme.isDark }"
						@click="$store.theme.set('dark')"
					>
						Dark
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-bind:class="{ 'btn-primary': $store.theme.isSystem }"
						@click="$store.theme.set('system')"
					>
						System
					</button>
					<button type="button" class="btn btn-sm btn-outline" @click="$store.theme.cycle()">
						Cycle
					</button>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Toggle <code class="text-base-content/60 font-normal">$toggle</code></h2>
				<div class="grid gap-4">
					<div x-data="&#123; power: $toggle(&#123; states: &#123; truly: 'on', falsely: 'off' &#125;, initial: 'off' &#125;) &#125;">
						<p>
							Binary:
							<strong x-text="power.value"></strong>
						</p>
						<div class="flex flex-wrap gap-2 mt-2">
							<button type="button" class="btn btn-sm btn-outline" @click="power.toggle()">Toggle</button>
							<button type="button" class="btn btn-sm btn-outline" @click="power.cycle()">Cycle</button>
							<span class="badge badge-outline" x-bind:class="&#123; 'badge-success': power.is(power.truly), 'badge-ghost': power.is(power.falsely) &#125;" x-text="power.value"></span>
						</div>
					</div>
					<div x-data="&#123; answer: $toggle(&#123; states: &#123; truly: 'yes', falsely: 'no', ternary: 'unknown' &#125;, initial: 'unknown' &#125;) &#125;">
						<p>
							Ternary:
							<strong x-text="answer.value"></strong>
							<span class="badge badge-warning ml-2" x-show="answer.is(answer.ternary)">neutral</span>
						</p>
						<div class="flex flex-wrap gap-2 mt-2">
							<button type="button" class="btn btn-sm btn-outline" @click="answer.toggle()">Yes / No</button>
							<button type="button" class="btn btn-sm btn-outline" @click="answer.cycle()">Cycle all</button>
							<button type="button" class="btn btn-sm btn-ghost" @click="answer.set(answer.ternary)">Unknown</button>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Screen <code class="text-base-content/60 font-normal">$store.device</code></h2>
				<p>
					Type: <strong x-text="$store.device.type"></strong> · Width:
					<strong x-text="$store.device.width"></strong>px
				</p>
				<div class="flex flex-wrap gap-2 mt-2">
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $store.device.is('mobile') }">
						Mobile
					</span>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $store.device.is('desktop') }">
						Desktop
					</span>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Scroll <code class="text-base-content/60 font-normal">$store.scroll</code></h2>
				<ul class="list-disc list-inside space-y-1">
					<li>Y: <strong x-text="Math.round($store.scroll.y)"></strong>px</li>
					<li>Direction: <strong x-text="$store.scroll.direction || '—'"></strong></li>
					<li>Progress: <strong x-text="Math.round($store.scroll.progress)"></strong>%</li>
					<li>Locked: <strong x-text="$store.scroll.isLocked"></strong></li>
				</ul>
				<div class="flex flex-wrap gap-2 mt-3">
					<button type="button" class="btn btn-sm btn-outline" @click="$store.scroll.toggleLock()">
						<span x-text="$store.scroll.isLocked ? 'Unlock scroll' : 'Lock scroll'"></span>
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$store.scroll.showToTop"
						x-cloak
						@click="$store.scroll.toTop()"
					>
						Back to top
					</button>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Network <code class="text-base-content/60 font-normal">$network</code></h2>
				<p
					class="font-semibold"
					x-bind:class="$network.isOnline ? 'text-success' : 'text-warning'"
					x-text="$network.isOnline ? 'Online' : 'Offline'"
				></p>
				<div class="flex flex-wrap gap-2 mt-3">
					<button type="button" class="btn btn-sm btn-outline" x-bind:disabled="!$network.isOnline">
						Save (requires connection)
					</button>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">
					Visibility <code class="text-base-content/60 font-normal">$visibility</code>
				</h2>
				<p
					class="font-semibold"
					x-bind:class="$visibility.isVisible ? 'text-success' : 'text-warning'"
					x-text="$visibility.isVisible ? 'Tab visible' : 'Tab hidden'"
				></p>
				<ul class="list-disc list-inside space-y-1">
					<li>State: <strong x-text="$visibility.state"></strong></li>
				</ul>
				<p class="text-sm text-base-content/70 mt-2">Switch to another tab to see the state update.</p>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Battery <code class="text-base-content/60 font-normal">$battery</code></h2>
				<template x-if="$battery.isAvailable">
					<div>
						<div class="flex items-center gap-3 mb-3" aria-hidden="true">
							<div class="battery-shell">
								<div
									class="battery-fill"
									x-bind:class="{
										'bg-warning': $battery.level < 0.2 && !$battery.isCharging,
										'bg-primary': $battery.isCharging,
										'bg-success': $battery.level >= 0.2 && !$battery.isCharging,
									}"
									x-bind:style="'width: ' + Math.round($battery.level * 100) + '%'"
								></div>
							</div>
							<span class="font-semibold tabular-nums" x-text="Math.round($battery.level * 100) + '%'"></span>
						</div>
						<p
							class="font-semibold"
							x-bind:class="$battery.isCharging ? 'text-success' : 'text-warning'"
							x-text="$battery.isCharging ? 'Charging' : 'On battery'"
						></p>
						<ul class="list-disc list-inside space-y-1 mt-2">
							<li x-show="$battery.chargingTime !== null">
								Time to full:
								<strong x-text="Math.round($battery.chargingTime / 60) + ' min'"></strong>
							</li>
							<li x-show="$battery.dischargingTime !== null">
								Time to empty:
								<strong x-text="Math.round($battery.dischargingTime / 60) + ' min'"></strong>
							</li>
						</ul>
						<div
							class="alert alert-warning mt-3 py-2 min-h-0"
							x-show="$battery.level < 0.2 && !$battery.isCharging"
							x-cloak
						>
							<span>Low battery — consider plugging in your device.</span>
						</div>
					</div>
				</template>
				<p class="text-sm text-base-content/70" x-show="!$battery.isAvailable" x-cloak>
					Battery status is not available on this device or browser.
				</p>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">
					Attention <code class="text-base-content/60 font-normal">$wakelock</code> ·
					<code class="text-base-content/60 font-normal">$idle</code>
				</h2>
				<div class="flex flex-wrap gap-2 mt-1">
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$wakelock.isSupported"
						x-cloak
						@click="$wakelock.isActive ? $wakelock.release() : $wakelock.request()"
						x-bind:disabled="$wakelock.isRequesting"
					>
						<span x-text="$wakelock.isActive ? 'Allow sleep' : 'Keep screen awake'"></span>
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$idle.isSupported && $idle.permission !== 'granted' && !$idle.isWatching"
						x-cloak
						@click="await $idle.requestPermission()"
						x-bind:disabled="$idle.isLoading"
					>
						Request idle permission
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$idle.isSupported && $idle.permission === 'granted' && !$idle.isWatching"
						x-cloak
						@click="await $idle.start()"
						x-bind:disabled="$idle.isLoading"
					>
						Start idle detection
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$idle.isWatching"
						x-cloak
						@click="$idle.stop()"
					>
						Stop idle detection
					</button>
				</div>
				<ul class="list-disc list-inside space-y-1 mt-3">
					<li>
						Wake lock:
						<strong
							x-text="$wakelock.isSupported ? ($wakelock.isActive ? 'active' : 'inactive') : 'unsupported'"
						></strong>
					</li>
					<li x-show="$idle.isSupported" x-cloak>
						Idle permission:
						<strong x-text="$idle.permission ?? 'unknown'"></strong>
					</li>
					<li x-show="$idle.isWatching" x-cloak>
						User: <strong x-text="$idle.userState"></strong> · Screen:
						<strong x-text="$idle.screenState"></strong>
					</li>
				</ul>
				<p class="text-sm text-base-content/70 mt-2" x-show="$idle.isSupported" x-cloak>
					Desktop: Chrome or Edge on localhost/HTTPS. Grant permission first, then start. Idle threshold
					is at least 1 minute.
				</p>
				<p class="text-sm text-base-content/70 mt-2" x-show="!$wakelock.isSupported && !$idle.isSupported" x-cloak>
					Wake Lock and Idle Detection are not available in this browser.
				</p>
				<p class="text-sm text-error mt-2" x-show="$wakelock.error" x-cloak x-text="$wakelock.error"></p>
				<p class="text-sm text-error mt-2" x-show="$idle.error" x-cloak x-text="$idle.error"></p>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">
					Clipboard <code class="text-base-content/60 font-normal">$clipboard</code>
				</h2>
				<button
					type="button"
					class="btn btn-sm btn-outline"
					@click="await $clipboard('Hello from Alpine!'); copied = true; setTimeout(() => copied = false, 2000)"
				>
					Copy text
				</button>
				<div class="alert alert-success mt-3 py-2 min-h-0" x-show="copied" x-cloak x-transition>
					<span>Copied to clipboard!</span>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Toast <code class="text-base-content/60 font-normal">$toast</code></h2>
				<p class="text-sm text-base-content/70">
					Headless queue — this demo renders stacks with DaisyUI
					<code class="text-base-content/60">toast</code> +
					<code class="text-base-content/60">alert</code> in
					<code class="text-base-content/60">BaseLayout.astro</code> (not part of the plugin).
				</p>
				<div class="flex flex-wrap gap-2 mt-3">
					<button type="button" class="btn btn-sm btn-outline" @click="$toast('Hello from Alpine!')">
						Default
					</button>
					<button type="button" class="btn btn-sm btn-outline btn-success" @click="$toast.success('Saved')">
						Success
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline btn-info"
						@click="$toast.info({ content: { kind: 'badge', label: 'Pro plan', seats: 3 } })"
					>
						Custom content
					</button>
					<button type="button" class="btn btn-sm btn-outline btn-warning" @click="$toast.warning('Careful')">
						Warning
					</button>
					<button type="button" class="btn btn-sm btn-outline btn-error" @click="$toast.error('Failed')">
						Error
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						@click="$toast('Top center', { position: 'top-center' })"
					>
						Top center
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						@click="$toast.warning({ title: 'File deleted', duration: 0, action: { label: 'Undo' }, content: { kind: 'undo-demo' } })"
					>
						Undo demo
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						@click="() => $toast.promise(() => new Promise((resolve) => setTimeout(() => resolve('done'), 1200)), { loading: 'Saving...', success: 'Saved!', error: 'Failed' })"
					>
						Promise
					</button>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Export <code class="text-base-content/60 font-normal">$export</code></h2>
				<p class="text-sm text-base-content/70" x-show="!$export.isSupported" x-cloak>
					Programmatic file exports are not available in this environment.
				</p>
				<template x-if="$export.isSupported">
					<div>
						<div class="flex flex-wrap gap-2 mt-1">
							<button
								type="button"
								class="btn btn-sm btn-outline"
								@click="exportedText = await $export('Hello from Alpine!', 'hello.txt')"
							>
								Export text
							</button>
							<button
								type="button"
								class="btn btn-sm btn-outline"
								@click="exportedJson = await $export(JSON.stringify(&#123; plugin: 'export', savedAt: Date.now() &#125;, null, 2), &#123; filename: 'export.json', mimeType: 'application/json' &#125;)"
							>
								Export JSON
							</button>
						</div>
						<div class="alert alert-success mt-3 py-2 min-h-0" x-show="exportedText === true" x-cloak x-transition>
							<span>Text export started.</span>
						</div>
						<div class="alert alert-success mt-3 py-2 min-h-0" x-show="exportedJson === true" x-cloak x-transition>
							<span>JSON export started.</span>
						</div>
					</div>
				</template>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Share <code class="text-base-content/60 font-normal">$share</code></h2>
				<p class="text-sm text-base-content/70" x-show="!$share.isSupported" x-cloak>
					Web Share API is not available in this browser.
				</p>
				<template x-if="$share.isSupported">
					<div>
						<button
							type="button"
							class="btn btn-sm btn-outline"
							@click="shared = await $share(&#123; title: document.title, text: 'Check out this Alpine.js plugin demo', url: window.location.href &#125;)"
						>
							Share page
						</button>
						<div class="alert alert-success mt-3 py-2 min-h-0" x-show="shared === true" x-cloak x-transition>
							<span>Thanks for sharing!</span>
						</div>
						<div class="alert alert-info mt-3 py-2 min-h-0" x-show="shared === false" x-cloak x-transition>
							<span>Share cancelled.</span>
						</div>
					</div>
				</template>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">
					Calendar <code class="text-base-content/60 font-normal">$calendar</code>
				</h2>
				<div x-data="{ cal: $calendar({ weekStartsOn: 1, mode: 'single', disabled: { dayOfWeek: [0, 6] } }) }">
					<div class="flex flex-wrap items-center gap-2">
						<button type="button" class="btn btn-sm btn-outline" @click="cal.prevMonth()">Previous</button>
						<strong x-text="cal.formatMonth()"></strong>
						<button type="button" class="btn btn-sm btn-outline" @click="cal.nextMonth()">Next</button>
						<button type="button" class="btn btn-sm btn-outline" @click="cal.goToToday()">Today</button>
					</div>

					<div class="grid grid-cols-7 gap-1 mt-3">
						<template x-for="label in cal.weekdayLabels" :key="label">
							<span class="text-center text-xs font-semibold text-base-content/60 py-1" x-text="label"></span>
						</template>
					</div>

					<template x-for="week in cal.weeks" :key="week[0].date.toISOString()">
						<div class="grid grid-cols-7 gap-1">
							<template x-for="day in week" :key="day.date.toISOString()">
								<button
									type="button"
									class="btn btn-sm btn-ghost btn-square tabular-nums"
									x-bind:disabled="day.isDisabled"
									x-bind:class="{ 'opacity-45': !day.isCurrentMonth, 'btn-outline btn-primary': day.isToday && !day.isSelected, 'btn-primary': day.isSelected }"
									@click="cal.select(day.date)"
									x-text="cal.format(day.date, 'd')"
								></button>
							</template>
						</div>
					</template>

					<p class="text-sm text-success mt-3" x-show="cal.selected" x-cloak>
						Selected:
						<strong x-text="cal.format(cal.selected, 'PPP')"></strong>
					</p>
					<p class="text-sm text-base-content/70 mt-2">
						Weekends are disabled via <code>disabled: &#123; dayOfWeek: [0, 6] &#125;</code>.
					</p>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Geo <code class="text-base-content/60 font-normal">$store.geo</code></h2>
				<p class="text-sm text-base-content/70" x-show="!$store.geo.isSupported" x-cloak>
					Geolocation is not available in this browser.
				</p>
				<template x-if="$store.geo.isSupported">
					<div>
						<div class="flex flex-wrap gap-2 mt-1">
							<button
								type="button"
								class="btn btn-sm btn-outline"
								@click="$store.geo.request(&#123; enableHighAccuracy: true &#125;)"
								x-bind:disabled="$store.geo.isLoading"
							>
								<span x-text="$store.geo.isLoading ? 'Locating…' : 'Get location'"></span>
							</button>
							<button
								type="button"
								class="btn btn-sm btn-outline"
								x-show="!$store.geo.isWatching"
								x-cloak
								@click="$store.geo.watch()"
							>
								Start tracking
							</button>
							<button
								type="button"
								class="btn btn-sm btn-outline"
								x-show="$store.geo.isWatching"
								x-cloak
								@click="$store.geo.unwatch()"
							>
								Stop tracking
							</button>
							<button type="button" class="btn btn-sm btn-outline" @click="$store.geo.reset()">Reset</button>
						</div>
						<p class="mt-3" x-show="$store.geo.hasPosition" x-cloak>
							Lat: <strong x-text="$store.geo.latitude?.toFixed(4)"></strong>,
							Lng: <strong x-text="$store.geo.longitude?.toFixed(4)"></strong>
							(±<strong x-text="Math.round($store.geo.accuracy ?? 0)"></strong> m)
						</p>
						<p class="text-sm text-error mt-2" x-show="$store.geo.hasError" x-cloak x-text="$store.geo.error"></p>
					</div>
				</template>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Query <code class="text-base-content/60 font-normal">$store.query</code></h2>
				<p class="text-sm text-base-content/70">
					Three state adapters — pick one for <code>query(&#123; adapter &#125;)</code>, then register
					<code>$store.query</code>. Each column runs the same paginated
					<a href="https://pokeapi.co/" target="_blank" rel="noreferrer" class="link link-primary">PokeAPI</a>
					demo. Nanostores uses <code>$store.query</code> globally; Alpine.reactive and Zustand use
					<code>createQueryClient</code>. Open the <strong>Query</strong> devtools button (bottom-right) to
					inspect caches from all three adapters.
				</p>

				<div class="grid gap-4 mt-4">
					<PokeapiQueryDemo
						dataName="queryNanostoresAdapterDemo"
						title="Nanostores"
						badgeClass="badge-primary"
					/>
					<PokeapiQueryDemo dataName="queryAlpineAdapterDemo" title="Alpine.reactive" />
					<PokeapiQueryDemo dataName="queryZustandAdapterDemo" title="Zustand" />
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200" x-data="jsonApiDemo" x-init="init()">
			<div class="card-body">
				<h2 class="card-title text-base">
					JSON:API <code class="text-base-content/60 font-normal">$jsonapi</code>
				</h2>
				<p class="text-sm text-base-content/70">
					Typed JSON:API client backed by a static compound document. Articles load via
					<code>jsonApiQueryOptions()</code> and <code>$store.query.observe()</code> with
					<code>include: ['author']</code>. Author names come from
					<code>relationships.author.resolved</code>.
				</p>
				<p class="text-sm text-base-content/60" x-show="query?.isLoading" x-cloak>Loading articles…</p>
				<p class="text-sm text-error" x-show="query?.isError" x-cloak x-text="query?.error?.message"></p>
				<div class="overflow-x-auto mt-3" x-show="query?.isSuccess" x-cloak>
					<table class="table table-sm">
						<thead>
							<tr>
								<th>ID</th>
								<th>Title</th>
								<th>Author</th>
							</tr>
						</thead>
						<tbody>
							<template x-for="row in rows" :key="row.id">
								<tr>
									<td x-text="row.id"></td>
									<td x-text="row.title"></td>
									<td x-text="row.author"></td>
								</tr>
							</template>
						</tbody>
					</table>
				</div>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Touch <code class="text-base-content/60 font-normal">$touch</code></h2>
				<ul class="list-disc list-inside space-y-1">
					<li>Touch: <strong x-text="$touch.isTouch"></strong></li>
					<li>Coarse pointer: <strong x-text="$touch.isCoarse"></strong></li>
					<li>Hover: <strong x-text="$touch.canHover"></strong></li>
					<li>Max touch points: <strong x-text="$touch.maxTouchPoints"></strong></li>
				</ul>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">
					Platform <code class="text-base-content/60 font-normal">$platform</code>
				</h2>
				<p>
					Detected OS: <strong x-text="$platform.name"></strong>
				</p>
				<div class="flex flex-wrap gap-2 mt-2">
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isMac }">macOS</span>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isWindows }"
						>Windows</span
					>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isLinux }">Linux</span>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isIos }">iOS</span>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isAndroid }"
						>Android</span
					>
					<span class="badge badge-outline" x-bind:class="{ 'badge-primary': $platform.isChromeos }"
						>ChromeOS</span
					>
				</div>
				<p class="text-sm text-base-content/70 mt-2" x-show="$platform.isMac" x-cloak>
					Use <kbd class="kbd kbd-sm">⌘</kbd> + <kbd class="kbd kbd-sm">C</kbd> to copy.
				</p>
				<p class="text-sm text-base-content/70 mt-2" x-show="$platform.isWindows || $platform.isLinux" x-cloak>
					Use <kbd class="kbd kbd-sm">Ctrl</kbd> + <kbd class="kbd kbd-sm">C</kbd> to copy.
				</p>
				<p class="text-sm text-base-content/70 mt-2" x-show="$platform.isIos || $platform.isAndroid" x-cloak>
					Touch-optimized shortcuts may differ from desktop.
				</p>
			</div>
		</section>

		<section class="card bg-base-100 shadow-sm border border-base-200">
			<div class="card-body">
				<h2 class="card-title text-base">Notify <code class="text-base-content/60 font-normal">$notify</code></h2>
				<ul class="list-disc list-inside space-y-1">
					<li>Supported: <strong x-text="$notify.isSupported"></strong></li>
					<li>Permission: <strong x-text="$notify.permission"></strong></li>
				</ul>
				<div class="alert alert-warning mt-3 py-2 min-h-0" x-show="$notify.requiresHomeScreenInstall" x-cloak>
					<span
						>On iPhone and iPad, add this site to your Home Screen and open it from there to enable
						notifications.</span
					>
				</div>
				<div class="flex flex-wrap gap-2 mt-3">
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$notify.isSupported && $notify.permission === 'default'"
						x-cloak
						@click="await $notify.requestPermission()"
					>
						Request permission
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$notify.isSupported && $notify.permission === 'granted'"
						x-cloak
						@click="await $notify.sendAsync('Task complete', &#123; body: 'Plugins are working correctly.' &#125;)"
					>
						Send notification
					</button>
					<button
						type="button"
						class="btn btn-sm btn-outline"
						x-show="$notify.isSupported"
						x-cloak
						@click="await $notify.sendIfPermittedAsync('Silent notification')"
					>
						sendIfPermitted
					</button>
				</div>
				<div
					class="alert alert-error mt-3 py-2 min-h-0"
					x-show="$notify.isSupported && $notify.permission === 'denied'"
					x-cloak
				>
					<span>Permission denied — enable notifications in your browser settings.</span>
				</div>
			</div>
		</section>

		<!-- Sidebar overlay — mobile only -->
		<div
			x-show="!$store.device?.is('desktop') && $store.sidebar.hasOverlay"
			x-transition.opacity
			class="fixed inset-0 bg-black/50 z-30"
			@click="$store.sidebar.hide()"
			style="display: none;"
		></div>

		<!-- Left sidebar — persistent on desktop, drawer on mobile -->
		<aside
			x-show="$store.device?.is('desktop') || $store.sidebar.open"
			x-transition:enter="transition ease-out duration-300"
			x-transition:enter-start="-translate-x-full"
			x-transition:enter-end="translate-x-0"
			x-transition:leave="transition ease-in duration-200"
			x-transition:leave-start="translate-x-0"
			x-transition:leave-end="-translate-x-full"
			class="fixed left-0 z-40 bg-base-100 shadow-xl flex flex-col overflow-hidden transition-[width] duration-300 ease-out"
			style="display: none;"
			x-bind:class="{
				'inset-y-0': true,
				'w-64': !$store.device?.is('desktop') || !$store.sidebar.collapsed,
				'w-16': $store.device?.is('desktop') && $store.sidebar.collapsed,
			}"
		>
			<!-- Logo -->
			<div class="flex items-center h-14 px-4 border-b border-base-200 shrink-0" :class="$store.sidebar.collapsed ? 'px-2' : 'px-4'">
				<div class="flex items-center gap-3 overflow-hidden">
					<img src="/logo.png" alt="ailuracode" class="w-8 h-8 rounded-lg shrink-0" />
					<span
						class="font-bold text-sm whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Alpine Plugins
					</span>
				</div>
			</div>

			<!-- Navigation -->
			<nav class="flex flex-col gap-0.5 p-2 flex-1 min-h-0 overflow-y-auto">
				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-primary/10 text-primary font-medium">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Dashboard
					</span>
				</a>
				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Pages
					</span>
				</a>
				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Media
					</span>
				</a>
				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Calendar
					</span>
				</a>

				<div class="divider my-1" x-show="!$store.sidebar.collapsed"></div>
				<div class="h-px bg-base-200 my-1 mx-3" x-show="$store.sidebar.collapsed"></div>

				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Analytics
					</span>
				</a>
				<a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-200 transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
					</svg>
					<span
						class="whitespace-nowrap overflow-hidden transition-[max-width,opacity] duration-300"
						x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
					>
						Settings
					</span>
				</a>
			</nav>

		</aside>
	</main>

	<footer class="footer footer-center p-6 text-base-content/60 text-sm">
		<nav>
			<a href="https://github.com/ailuracode/alpine" target="_blank" rel="noreferrer" class="link link-hover">
				Source
			</a>
			<a href="https://www.npmjs.com/~siddharthagf" target="_blank" rel="noreferrer" class="link link-hover">
				npm
			</a>
		</nav>
	</footer>
</BaseLayout>
