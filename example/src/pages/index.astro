---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
	<main class="main">
		<section class="card">
			<h2>Theme <code>$store.theme</code></h2>
			<p>
				Mode: <strong x-text="$store.theme.mode"></strong> → resolved:
				<strong x-text="$store.theme.resolved"></strong>
			</p>
			<div class="btn-group">
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isLight }"
					@click="$store.theme.set('light')"
				>
					Light
				</button>
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isDark }"
					@click="$store.theme.set('dark')"
				>
					Dark
				</button>
				<button
					type="button"
					x-bind:class="{ active: $store.theme.isSystem }"
					@click="$store.theme.set('system')"
				>
					System
				</button>
				<button type="button" @click="$store.theme.cycle()">Cycle</button>
			</div>
		</section>

		<section class="card">
			<h2>Screen <code>$store.device</code></h2>
			<p>
				Type: <strong x-text="$store.device.type"></strong> · Width:
				<strong x-text="$store.device.width"></strong>px
			</p>
			<div class="badges">
				<span class="badge" x-bind:class="{ on: $store.device.isMobile }">Mobile</span>
				<span class="badge" x-bind:class="{ on: $store.device.isTablet }">Tablet</span>
				<span class="badge" x-bind:class="{ on: $store.device.isDesktop }">Desktop</span>
			</div>
		</section>

		<section class="card">
			<h2>Scroll <code>$store.scroll</code></h2>
			<ul class="list">
				<li>Y: <strong x-text="Math.round($store.scroll.y)"></strong>px</li>
				<li>Direction: <strong x-text="$store.scroll.direction || '—'"></strong></li>
				<li>Progress: <strong x-text="Math.round($store.scroll.progress)"></strong>%</li>
				<li>Locked: <strong x-text="$store.scroll.isLocked"></strong></li>
			</ul>
			<div class="btn-group">
				<button type="button" @click="$store.scroll.toggleLock()">
					<span x-text="$store.scroll.isLocked ? 'Unlock scroll' : 'Lock scroll'"></span>
				</button>
				<button type="button" x-show="$store.scroll.showToTop" x-cloak @click="$store.scroll.toTop()">
					Back to top
				</button>
			</div>
		</section>

		<section class="card">
			<h2>Network <code>$network</code></h2>
			<p
				class="status"
				x-bind:class="$network.isOnline ? 'status--ok' : 'status--warn'"
				x-text="$network.isOnline ? 'Online' : 'Offline'"
			></p>
			<div class="btn-group">
				<button type="button" x-bind:disabled="!$network.isOnline">Save (requires connection)</button>
			</div>
		</section>

		<section class="card">
			<h2>Clipboard <code>$clipboard</code></h2>
			<button
				type="button"
				@click="await $clipboard('Hello from Alpine!'); copied = true; setTimeout(() => copied = false, 2000)"
			>
				Copy text
			</button>
			<p class="hint" x-show="copied" x-cloak x-transition>Copied to clipboard!</p>
		</section>

		<section class="card">
			<h2>Touch <code>$touch</code></h2>
			<ul class="list">
				<li>Touch: <strong x-text="$touch.isTouch"></strong></li>
				<li>Coarse pointer: <strong x-text="$touch.isCoarse"></strong></li>
				<li>Hover: <strong x-text="$touch.canHover"></strong></li>
				<li>Max touch points: <strong x-text="$touch.maxTouchPoints"></strong></li>
			</ul>
		</section>

		<section class="card">
			<h2>Platform <code>$platform</code></h2>
			<p>
				Detected OS: <strong x-text="$platform.name"></strong>
			</p>
			<div class="badges">
				<span class="badge" x-bind:class="{ on: $platform.isMac }">macOS</span>
				<span class="badge" x-bind:class="{ on: $platform.isWindows }">Windows</span>
				<span class="badge" x-bind:class="{ on: $platform.isLinux }">Linux</span>
				<span class="badge" x-bind:class="{ on: $platform.isIos }">iOS</span>
				<span class="badge" x-bind:class="{ on: $platform.isAndroid }">Android</span>
				<span class="badge" x-bind:class="{ on: $platform.isChromeos }">ChromeOS</span>
			</div>
			<p class="hint" x-show="$platform.isMac" x-cloak>Use <kbd>⌘</kbd> + <kbd>C</kbd> to copy.</p>
			<p class="hint" x-show="$platform.isWindows || $platform.isLinux" x-cloak>
				Use <kbd>Ctrl</kbd> + <kbd>C</kbd> to copy.
			</p>
			<p class="hint" x-show="$platform.isIos || $platform.isAndroid" x-cloak>
				Touch-optimized shortcuts may differ from desktop.
			</p>
		</section>

		<section class="card">
			<h2>Notify <code>$notify</code></h2>
			<ul class="list">
				<li>Supported: <strong x-text="$notify.isSupported()"></strong></li>
				<li>Permission: <strong x-text="$notify.permission()"></strong></li>
			</ul>
			<p class="hint hint--error" x-show="$notify.requiresHomeScreenInstall()" x-cloak>
				On iPhone and iPad, add this site to your Home Screen and open it from there to enable notifications.
			</p>
			<div class="btn-group">
				<button
					type="button"
					x-show="$notify.isSupported() && $notify.permission() === 'default'"
					x-cloak
					@click="await $notify.requestPermission()"
				>
					Request permission
				</button>
				<button
					type="button"
					x-show="$notify.isSupported() && $notify.permission() === 'granted'"
					x-cloak
					@click="await $notify.sendAsync('Task complete', { body: 'Plugins are working correctly.' })"
				>
					Send notification
				</button>
				<button
					type="button"
					x-show="$notify.isSupported()"
					x-cloak
					@click="await $notify.sendIfPermittedAsync('Silent notification')"
				>
					sendIfPermitted
				</button>
			</div>
			<p class="hint hint--error" x-show="$notify.isSupported() && $notify.permission() === 'denied'" x-cloak>
				Permission denied — enable notifications in your browser settings.
			</p>
		</section>
	</main>

	<footer class="footer">
		<p>
			<a href="https://github.com/ailuracode/alpine" target="_blank" rel="noreferrer">Source</a>
			·
			<a href="https://www.npmjs.com/~siddharthagf" target="_blank" rel="noreferrer">npm</a>
		</p>
	</footer>
</BaseLayout>
