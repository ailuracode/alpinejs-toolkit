---
import globalStyles from "../styles/global.css?raw";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Alpine.js + @ailuracode",
	description = "Interactive demo of @ailuracode plugins for Alpine.js",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				var key = "theme";
				var saved = localStorage.getItem(key);
				var mode =
					saved === "light" || saved === "dark" || saved === "system" ? saved : "system";
				var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				var resolved = mode === "system" ? (dark ? "dark" : "light") : mode;
				document.documentElement.dataset.theme = resolved;
				document.documentElement.style.colorScheme = resolved;
			})();
		</script>
		<style is:inline set:html={globalStyles}></style>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="app" x-data="{ copied: false }" x-cloak>
			<header class="header">
				<h1>Alpine.js + @ailuracode</h1>
				<p class="subtitle">Demo with all eight plugins · Astro</p>
			</header>

			<div class="progress-bar" aria-hidden="true">
				<div
					class="progress-bar-fill"
					x-bind:style="'width: ' + $store.scroll.progress + '%'"
				></div>
			</div>

			<slot />

			<div class="spacer" aria-hidden="true"></div>

			<button
				type="button"
				class="fab"
				x-show="$store.scroll.showToTop"
				x-cloak
				@click="$store.scroll.toTop()"
				aria-label="Back to top"
			>
				↑
			</button>
		</div>

		<script>
			import Alpine from "alpinejs";
			import register from "../entrypoint";

			register(Alpine);
			window.Alpine = Alpine;
			Alpine.start();
		</script>
	</body>
</html>
