---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alpine.js + @ailuracode",
  description = "Interactive demo of @ailuracode plugins for Alpine.js",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				var key = "theme";
				var saved = localStorage.getItem(key);
				var mode =
					saved === "light" || saved === "dark" || saved === "system" ? saved : "system";
				var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				var resolved = mode === "system" ? (dark ? "dark" : "light") : mode;
				document.documentElement.dataset.theme = resolved;
				document.documentElement.style.colorScheme = resolved;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-base-200 text-base-content">
		<div
			class="min-h-screen"
			x-data="{ copied: false, exportedText: null, exportedJson: null, shared: null }"
			x-cloak
		>
			<header class="sticky top-0 z-30 bg-base-100 border-b border-base-300 transition-[margin] duration-300" x-bind:class="$store.device?.is('desktop') ? ($store.sidebar.collapsed ? 'ml-16' : 'ml-64') : ''">
				<div class="flex items-center gap-3 px-4 h-14">
					<button
						type="button"
						class="btn btn-sm btn-ghost btn-square shrink-0"
						@click="$store.device?.is('desktop') ? $store.sidebar.toggleCollapse() : $store.sidebar.toggle()"
						aria-label="Toggle sidebar"
					>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
					<div class="min-w-0">
						<h1 class="text-lg font-bold truncate">Alpine.js + @ailuracode</h1>
						<p class="text-xs text-base-content/70 truncate leading-tight">Interactive demo of all plugins · Astro · DaisyUI</p>
					</div>
				</div>
			</header>

			<div class="fixed top-0 left-0 right-0 z-50 h-1 bg-base-300" aria-hidden="true">
				<div
					class="h-full bg-primary transition-[width] duration-100 linear"
					x-bind:style="'width: ' + $store.scroll.progress + '%'"
				></div>
			</div>

			<slot />

			<button
				type="button"
				class="btn btn-primary btn-circle fixed bottom-6 right-6 shadow-lg z-40"
				x-show="$store.scroll.showToTop"
				x-cloak
				@click="$store.scroll.toTop()"
				aria-label="Back to top"
			>
				↑
			</button>

			<template x-for="position in $store.toast.stackPositions" :key="position">
				<div
					class="toast toast-demo-stack z-[60]"
					x-data
					x-show="$store.toast.itemsAt(position).some((toast) => !toast.removed)"
					x-bind:class="{
						'toast-bottom toast-end': position === 'bottom-right',
						'toast-top toast-center': position === 'top-center',
					}"
				>
					<template x-for="(toast, index) in $store.toast.itemsAt(position)" :key="toast.id">
						<div
							class="toast-demo-item alert shadow-lg py-2 px-3 min-h-0 w-full !flex !items-center !gap-2 origin-center"
							role="alert"
							x-bind:data-position="toast.position"
							x-bind:data-toast-motion="position === 'top-center' ? 'top' : 'bottom'"
							x-bind:class="{
								'alert-success': toast.variant === 'success',
								'alert-info': toast.variant === 'info' || toast.variant === 'loading',
								'alert-warning': toast.variant === 'warning',
								'alert-error': toast.variant === 'error',
							}"
							x-show="!toast.removed && $store.toast.isVisibleAt(position, index)"
							x-transition:leave="transition duration-300 ease-in"
							x-transition:leave-start="opacity-100 translate-y-0 scale-100"
							x-transition:leave-end="position === 'top-center' ? 'opacity-0 -translate-y-full scale-[0.96]' : 'opacity-0 translate-y-full scale-[0.96]'"
						>
							<div
								class="flex h-8 w-8 shrink-0 items-center justify-center"
								x-show="toast.variant === 'loading'"
								aria-hidden="true"
							>
								<span class="loading loading-spinner loading-sm"></span>
							</div>
							<div class="min-w-0 flex-1">
								<span
									x-show="toast.content?.kind === 'badge'"
									class="badge badge-sm badge-outline"
									x-text="toast.content?.label"
								></span>
								<span class="font-medium leading-snug" x-show="toast.title" x-text="toast.title"></span>
								<p
									class="text-sm opacity-80 leading-snug"
									x-show="toast.description"
									x-text="toast.description"
								></p>
							</div>
							<div class="flex shrink-0 items-center justify-end gap-1 min-w-16">
								<button
									type="button"
									class="btn btn-sm btn-ghost h-8 min-h-8 px-2 uppercase tracking-wide"
									x-show="toast.content?.kind === 'undo-demo' && toast.action && toast.variant !== 'loading'"
									x-text="toast.action.label"
									@click="
										$toast.update(toast.id, {
											variant: 'loading',
											title: 'Undoing…',
											description: null,
											action: null,
											duration: 0,
										});
										setTimeout(() => {
											$toast.update(toast.id, {
												variant: 'success',
												title: 'Change undone',
												description: null,
												action: null,
												duration: 4000,
											});
										}, 1200);
									"
								></button>
								<button
									type="button"
									class="btn btn-sm btn-ghost btn-square h-8 min-h-8 w-8"
									x-show="toast.variant !== 'loading'"
									@click="$toast.dismiss(toast.id)"
									aria-label="Dismiss notification"
								>
									✕
								</button>
							</div>
						</div>
					</template>
				</div>
			</template>
		</div>

		<script>
			import Alpine from "alpinejs";
			import register from "../entrypoint";

			register(Alpine);
			window.Alpine = Alpine;
			Alpine.start();
		</script>
	</body>
</html>
