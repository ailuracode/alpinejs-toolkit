---
interface Props {
	dataName: string;
	title: string;
	badgeClass?: string;
}

const { dataName, title, badgeClass = "" } = Astro.props;
---

<article
	class="query-adapter"
	x-data={dataName}
	x-init="init()"
	@destroy="destroy()"
>
	<h3 class="query-adapter__title">
		{title}
		<span
			class:list={["badge", badgeClass]}
			x-bind:class="{ on: query?.isSuccess }"
			x-text="badge"
		></span>
	</h3>
	<p class="hint">
		<slot name="description" />
	</p>

	<p class="hint hint--error" x-show="query?.isError" x-text="query?.error?.message"></p>

	<div class="query-table-panel">
		<p class="query-table-meta hint">
			Page <strong x-text="page"></strong>
			· showing <strong x-text="rows.length || pageSize"></strong>
			of <strong x-text="totalCount || '…'"></strong> Pokémon
		</p>

		<div
			class="query-table-wrap"
			x-bind:class="{
				'is-fetching': query?.isFetching && hasCachedPage,
				'is-awaiting-data': isAwaitingData,
			}"
			x-bind:aria-busy="isAwaitingData || query?.isFetching"
		>
			<table class="query-table">
				<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Name</th>
					</tr>
				</thead>
				<tbody>
					<template x-for="row in tableRows" :key="page + '-' + row.id">
						<tr x-bind:class="{ 'is-loading': row.loading }">
							<td>
								<span
									class="query-table-skeleton"
									x-show="row.loading"
									x-text="row.id"
									aria-hidden="true"
								></span>
								<span x-show="!row.loading" x-text="row.id"></span>
							</td>
							<td>
								<span
									class="query-table-skeleton"
									x-show="row.loading"
									x-text="row.name"
									aria-hidden="true"
								></span>
								<span x-show="!row.loading" x-text="row.name"></span>
							</td>
						</tr>
					</template>
				</tbody>
			</table>
		</div>
	</div>

	<div class="btn-group">
		<button type="button" @click="prevPage()" x-bind:disabled="page <= 1 || query?.isFetching">
			Previous
		</button>
		<button
			type="button"
			@click="query?.refetch()"
			x-bind:disabled="!query || query.isFetching"
		>
			Refresh
		</button>
		<button
			type="button"
			@click="nextPage()"
			x-bind:disabled="!query?.data?.next || query?.isFetching"
		>
			Next
		</button>
	</div>
</article>
