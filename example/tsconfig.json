{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@ailuracode/alpine-battery": ["../packages/battery/src/index.ts"],
      "@ailuracode/alpine-clipboard": ["../packages/clipboard/src/index.ts"],
      "@ailuracode/alpine-export": ["../packages/export/src/index.ts"],
      "@ailuracode/alpine-geo": ["../packages/geo/src/index.ts"],
      "@ailuracode/alpine-network": ["../packages/network/src/index.ts"],
      "@ailuracode/alpine-notify": ["../packages/notify/src/index.ts"],
      "@ailuracode/alpine-platform": ["../packages/platform/src/index.ts"],
      "@ailuracode/alpine-screen": ["../packages/screen/src/index.ts"],
      "@ailuracode/alpine-scroll": ["../packages/scroll/src/index.ts"],
      "@ailuracode/alpine-share": ["../packages/share/src/index.ts"],
      "@ailuracode/alpine-theme": ["../packages/theme/src/index.ts"],
      "@ailuracode/alpine-touch": ["../packages/touch/src/index.ts"],
      "@ailuracode/alpine-visibility": ["../packages/visibility/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "preserve",
    "strict": true
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
