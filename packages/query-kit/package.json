{
  "name": "@ailuracode/alpine-query-kit",
  "version": "0.0.0",
  "description": "Alpine query cache with Nanostores adapter and devtools panel",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/query-kit"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/query-kit#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "peerDependencies": {
    "@nanostores/alpine": "^0.1.0",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.0.0",
    "nanostores": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "dependencies": {
    "@ailuracode/alpine-query": "workspace:*",
    "@nanostores/alpine": "^0.1.1",
    "nanostores": "^1.4.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --out-dir dist --tsconfig tsconfig.build.json --external @ailuracode/alpine-query --external @nanostores/alpine --external nanostores && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "query",
    "nanostores",
    "devtools"
  ]
}
