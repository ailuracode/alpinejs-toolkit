{
  "name": "@ailuracode/alpine-attention",
  "version": "2.0.0",
  "description": "Alpine.js Screen Wake Lock and Idle Detection magics",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/attention"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/attention#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "default": "./dist/controller.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@ailuracode/alpine-permissions": "workspace:*",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.3.0",
    "@ailuracode/alpine-permissions": "^1.0.0",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/controller.ts --format esm --dts --clean --out-dir dist --minify --external @ailuracode/alpine-permissions && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/attention",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "wake-lock",
    "wakelock",
    "idle-detection",
    "idle",
    "screen"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "small-feature"
    }
  },
  "size-limit": [
    {
      "name": "plugin surface",
      "path": "dist/index.js",
      "import": "{ attentionPlugin }",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@types/alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "2.5 kB"
    }
  ]
}
