{
  "name": "@ailuracode/alpine-query-adapter-zustand",
  "version": "4.0.4",
  "description": "Zustand adapter plugin for @ailuracode/alpine-query",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/main/packages/query-adapter-zustand#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/query-adapter-zustand"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@ailuracode/alpine-query": "workspace:*",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "dependencies": {
    "@ailuracode/alpine-query": "workspace:*",
    "@ailuracode/alpine-query-adapter-alpine": "workspace:*",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist --tsconfig tsconfig.build.json --minify",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/query-adapter-zustand"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "query",
    "zustand",
    "adapter"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "adapter"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-query",
        "@ailuracode/alpine-query-adapter-alpine",
        "@types/alpinejs",
        "zustand"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "700 B"
    }
  ]
}
