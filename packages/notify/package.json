{
  "name": "@ailuracode/alpine-notify",
  "version": "2.0.0",
  "description": "Alpine.js Web Notifications API magic",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/notify"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/notify#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    },
    "./notify-sw.js": "./dist/notify-sw.js"
  },
  "types": "./dist/global.d.ts",
  "dependencies": {
    "@ailuracode/alpine-env": "workspace:*"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@ailuracode/alpine-permissions": "workspace:*",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.3.0",
    "@ailuracode/alpine-permissions": "^1.0.0",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist --minify --external @ailuracode/alpine-env --external @ailuracode/alpine-permissions && cp src/global.d.ts dist/global.d.ts && cp src/notify-sw.js dist/notify-sw.js",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/notify",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "notifications",
    "web-notifications",
    "notify",
    "permission"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "small-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@types/alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1.9 kB"
    }
  ]
}
