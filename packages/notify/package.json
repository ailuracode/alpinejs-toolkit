{
  "name": "@ailuracode/alpine-notify",
  "version": "0.3.2",
  "description": "Alpine.js Web Notifications API magic",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/notify"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/notify#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    },
    "./notify-sw.js": "./dist/notify-sw.js"
  },
  "types": "./dist/global.d.ts",
  "dependencies": {
    "@ailuracode/alpine-platform": "workspace:*"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --out-dir dist && cp src/global.d.ts dist/global.d.ts && cp src/notify-sw.js dist/notify-sw.js",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "notifications",
    "web-notifications",
    "notify",
    "permission"
  ]
}
