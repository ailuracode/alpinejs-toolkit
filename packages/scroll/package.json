{
  "name": "@ailuracode/alpine-scroll",
  "version": "1.0.0",
  "description": "Alpine.js scroll controller — headless position tracking, body lock, section observer, navigation",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/scroll"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/scroll#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "peerDependencies": {
    "alpinejs": "^3.0.0",
    "@ailuracode/alpine-core": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome check --assist-enabled=true .",
    "lint:fix": "biome check --write --assist-enabled=true .",
    "test": "vitest run --config ../../vitest.config.ts packages/scroll",
    "test:watch": "vitest --config ../../vitest.config.ts packages/scroll",
    "test:coverage": "vitest run --coverage --coverage.include=packages/scroll/src/**/*.ts --coverage.exclude=packages/scroll/src/index.ts --coverage.exclude=packages/scroll/src/global.d.ts --coverage.exclude=packages/scroll/src/types.ts --coverage.exclude=packages/scroll/src/events.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=70 --coverage.thresholds.statements=80 --coverage.thresholds.branches=73 --config ../../vitest.config.ts packages/scroll",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.0"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "scroll",
    "scroll-lock",
    "controller",
    "headless"
  ]
}
