{
  "name": "@ailuracode/alpine-child",
  "version": "1.0.0",
  "description": "Alpine.js x-child directive — asChild-style attribute transfer to the first child element",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/child"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/child#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.0",
    "@alpinejs/morph": "^3.0.0",
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@alpinejs/morph": "^3.15.12",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test",
    "test:watch": "vitest --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "directive",
    "as-child",
    "headless"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "small-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@alpinejs/morph"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1.5 kB"
    }
  ]
}
