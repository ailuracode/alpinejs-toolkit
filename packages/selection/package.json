{
  "name": "@ailuracode/alpine-selection",
  "version": "0.0.0",
  "description": "Framework-agnostic selection primitives for Alpine.js — single, multiple, and range modes",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/selection"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/selection#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.0",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "selection",
    "listbox",
    "headless",
    "accessibility"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "complex-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@types/alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "6 kB"
    }
  ]
}
