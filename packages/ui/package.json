{
  "name": "@ailuracode/alpine-ui",
  "version": "1.0.0",
  "description": "Framework-agnostic UI primitives for @ailuracode/alpinejs-toolkit — storage adapters, media query listeners, and portal helpers.",
  "keywords": [
    "alpine",
    "alpinejs",
    "headless",
    "plugin",
    "primitives",
    "storage"
  ],
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/ui#readme",
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "license": "MIT",
  "author": "ailuracode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "clean": "rm -rf dist",
    "size": "size-limit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.0"
  },
  "toolkit": {
    "bundleBudget": {
      "category": "primitive"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "850 B"
    }
  ]
}
