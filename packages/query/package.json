{
  "name": "@ailuracode/alpine-query",
  "version": "0.6.1",
  "description": "Store-agnostic async data fetching for Alpine.js with TanStack Query-style caching",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/query"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/query#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapters/vanilla": {
      "types": "./dist/adapters/vanilla.d.ts",
      "default": "./dist/adapters/vanilla.js"
    },
    "./instrumentation": {
      "types": "./dist/instrumentation.d.ts",
      "default": "./dist/instrumentation.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/adapters/vanilla.ts src/instrumentation-entry.ts --format esm --dts --clean --out-dir dist && mv dist/instrumentation-entry.js dist/instrumentation.js && mv dist/instrumentation-entry.d.ts dist/instrumentation.d.ts && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "query",
    "cache",
    "fetch",
    "tanstack-query",
    "async"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "infrastructure"
    }
  },
  "size-limit": [
    {
      "name": "intrinsic full",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@types/alpinejs"
      ],
      "gzip": true,
      "limit": "4307 B"
    }
  ]
}
