{
  "name": "@ailuracode/alpine-keyboard",
  "version": "0.1.0",
  "description": "Headless scoped keyboard shortcut registry with chords, sequences, and conflict resolution",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/keyboard"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/keyboard#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "default": "./dist/controller.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.1",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@types/alpinejs": "^3.13.11"
  },
  "scripts": {
    "build": "tsup src/index.ts src/controller.ts --format esm --dts --clean --out-dir dist --minify && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/keyboard",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "keyboard",
    "shortcuts",
    "hotkeys",
    "keybindings"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "infrastructure"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@types/alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "3.4 kB"
    }
  ]
}
