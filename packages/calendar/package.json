{
  "name": "@ailuracode/alpine-calendar",
  "version": "0.1.2",
  "description": "Alpine.js calendar date logic with a native Date/Intl adapter (optional date-fns adapter)",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/calendar"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/calendar#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./date-fns": {
      "types": "./dist/date-fns.d.ts",
      "default": "./dist/date-fns.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "dependencies": {},
  "optionalDependencies": {
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "date-fns": "^4.1.0"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.0",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/date-fns-entry.ts --format esm --dts --clean --out-dir dist --external date-fns && mv dist/date-fns-entry.js dist/date-fns.js && mv dist/date-fns-entry.d.ts dist/date-fns.d.ts && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "calendar",
    "date",
    "date-fns",
    "datepicker"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "complex-feature"
    }
  },
  "size-limit": [
    {
      "name": "default import",
      "path": "dist/index.js",
      "import": "calendarPlugin",
      "ignore": [
        "alpinejs",
        "@types/alpinejs"
      ],
      "gzip": true,
      "limit": "4.5 kB"
    },
    {
      "name": "intrinsic full",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@types/alpinejs",
        "@ailuracode/alpine-core"
      ],
      "gzip": true,
      "limit": "8.9 kB"
    },
    {
      "name": "date-fns adapter",
      "path": "dist/date-fns.js",
      "import": "{ createDateFnsCalendarAdapter }",
      "ignore": [
        "alpinejs",
        "@types/alpinejs",
        "date-fns"
      ],
      "gzip": true,
      "limit": "1.5 kB"
    }
  ]
}
