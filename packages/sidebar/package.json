{
  "name": "@ailuracode/alpine-sidebar",
  "version": "3.0.0",
  "description": "Alpine.js sidebar store for visibility state, overlay, keyboard navigation, and responsive breakpoints",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/sidebar"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/sidebar#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "types": "./dist/global.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0",
    "@ailuracode/alpine-core": "^0.2.0",
    "@ailuracode/alpine-toggle": "^1.0.0",
    "@ailuracode/alpine-scroll": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    },
    "@ailuracode/alpine-scroll": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/sidebar",
    "test:coverage": "vitest run --coverage --config ../../vitest.config.ts packages/sidebar",
    "test:watch": "vitest --config ../../vitest.config.ts packages/sidebar",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@ailuracode/alpine-scroll": "workspace:*",
    "@ailuracode/alpine-toggle": "workspace:*",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.0"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "sidebar",
    "navigation",
    "drawer",
    "controller",
    "headless"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "complex-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@ailuracode/alpine-toggle",
        "@ailuracode/alpine-scroll"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "2.6 kB"
    }
  ]
}
