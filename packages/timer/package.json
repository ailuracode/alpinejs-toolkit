{
  "name": "@ailuracode/alpine-timer",
  "version": "0.0.0",
  "description": "Alpine.js timer magic with countdown, countup, and stopwatch presets backed by a drift-resistant timing engine.",
  "keywords": [
    "alpine",
    "alpinejs",
    "countdown",
    "countup",
    "magic",
    "plugin",
    "stopwatch",
    "timer"
  ],
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/timer#readme",
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "license": "MIT",
  "author": "ailuracode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/timer"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/global.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "clean": "rm -rf dist",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report",
    "test:watch": "vitest --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@playwright/test": "^1.56.1",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.0",
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "toolkit": {
    "bundleBudget": {
      "category": "small-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "3 kB"
    }
  ]
}
