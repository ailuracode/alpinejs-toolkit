{
  "name": "@ailuracode/alpine-carousel",
  "version": "1.0.0",
  "description": "Alpine.js headless accessible carousel store powered by Embla Carousel",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/carousel"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/carousel#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./autoplay": {
      "types": "./dist/autoplay.d.ts",
      "default": "./dist/autoplay.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "dependencies": {
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.0",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/autoplay-entry.ts --format esm --dts --clean --out-dir dist && mv dist/autoplay-entry.js dist/autoplay.js && mv dist/autoplay-entry.d.ts dist/autoplay.d.ts && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts test",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "carousel",
    "slider",
    "embla",
    "accessibility",
    "headless"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "complex-feature"
    }
  },
  "size-limit": [
    {
      "name": "default import",
      "path": "dist/index.js",
      "import": "carouselPlugin",
      "ignore": [
        "alpinejs",
        "@types/alpinejs"
      ],
      "gzip": true,
      "limit": "11.2 kB"
    },
    {
      "name": "intrinsic full",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@types/alpinejs",
        "@ailuracode/alpine-core",
        "embla-carousel",
        "embla-carousel-autoplay"
      ],
      "gzip": true,
      "limit": "12 kB"
    },
    {
      "name": "autoplay chunk",
      "path": "dist/autoplay.js",
      "import": "{ loadAutoplayPlugin }",
      "ignore": [
        "embla-carousel-autoplay"
      ],
      "gzip": true,
      "limit": "1 kB"
    }
  ]
}
