{
  "name": "@ailuracode/alpine-command",
  "version": "1.1.1",
  "description": "Alpine.js headless command palette store",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/command"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/master/packages/command#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "types": "./dist/global.d.ts",
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@ailuracode/alpine-scroll": "workspace:*",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.2.2",
    "@ailuracode/alpine-scroll": "^2.0.2",
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@ailuracode/alpine-scroll": {
      "optional": true
    },
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist --minify && cp src/global.d.ts dist/global.d.ts",
    "prepublishOnly": "pnpm run build",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/command",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "command",
    "palette",
    "spotlight",
    "headless"
  ],
  "toolkit": {
    "bundleBudget": {
      "category": "complex-feature"
    }
  },
  "size-limit": [
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs",
        "@ailuracode/alpine-core",
        "@types/alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "4 kB"
    }
  ]
}
