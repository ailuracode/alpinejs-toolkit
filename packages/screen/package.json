{
  "name": "@ailuracode/alpine-screen",
  "version": "0.2.0",
  "description": "Alpine.js responsive device and viewport store",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpine.git",
    "directory": "packages/screen"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpine/issues"
  },
  "homepage": "https://github.com/ailuracode/alpine/tree/master/packages/screen#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "alpinejs": "^3.0.0",
    "@types/alpinejs": "^3.13.11"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --out-dir dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --config ../../vitest.config.js test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "responsive",
    "breakpoint",
    "device"
  ]
}
