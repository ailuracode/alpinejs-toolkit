{
  "name": "@ailuracode/alpine-query-adapter-alpine",
  "version": "3.0.1",
  "description": "Native Alpine.reactive adapter plugin for @ailuracode/alpine-query",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpine.git",
    "directory": "packages/query-adapter-alpine"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "@ailuracode/alpine-query": "workspace:*",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "dependencies": {
    "@ailuracode/alpine-query": "workspace:*"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --sourcemap --out-dir dist --tsconfig tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "query",
    "adapter"
  ]
}
