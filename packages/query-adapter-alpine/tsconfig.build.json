{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "baseUrl": "../..",
    "paths": {
      "@ailuracode/alpinejs-query": ["packages/query/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
