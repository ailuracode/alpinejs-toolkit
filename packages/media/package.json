{
  "name": "@ailuracode/alpine-media",
  "version": "0.2.0",
  "description": "Reactive viewport breakpoints, dimensions, and browser media features store for Alpine.js — controller-based architecture.",
  "type": "module",
  "license": "MIT",
  "author": "ailuracode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/media"
  },
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/main/packages/media#readme",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "types": "./dist/global.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --config ../../vitest.config.ts test",
    "test:watch": "vitest --config ../../vitest.config.ts"
  },
  "devDependencies": {
    "@ailuracode/alpine-core": "workspace:*",
    "@types/alpinejs": "^3.13.10",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "@ailuracode/alpine-core": "^0.1.0",
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "keywords": [
    "alpinejs",
    "alpine",
    "plugin",
    "responsive",
    "breakpoint",
    "media-query",
    "viewport"
  ]
}
