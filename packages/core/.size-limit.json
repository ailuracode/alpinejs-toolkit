[
  {
    "name": "minimal (registerPlugin + definePlugin)",
    "path": "dist/index.js",
    "import": "{ registerPlugin, definePlugin }",
    "ignore": ["alpinejs"],
    "gzip": true,
    "brotli": true,
    "limit": "400 B"
  },
  {
    "name": "typical (registry + browser helpers)",
    "path": "dist/index.js",
    "import": "{ registerPlugin, definePlugin, initPlugins, isBrowser, safeWindow }",
    "ignore": ["alpinejs"],
    "gzip": true,
    "brotli": true,
    "limit": "1.1 kB"
  },
  {
    "name": "full surface",
    "path": "dist/index.js",
    "import": "*",
    "ignore": ["alpinejs"],
    "gzip": true,
    "brotli": true,
    "limit": "2.9 kB"
  }
]
