{
  "name": "@ailuracode/alpine-core",
  "version": "0.2.0",
  "description": "Headless controller primitives, Alpine bridge helpers, and browser capability utilities for Alpine.js.",
  "keywords": [
    "alpine",
    "alpinejs",
    "controller",
    "headless",
    "plugin",
    "tree-shaking"
  ],
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "license": "MIT",
  "author": "ailuracode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/global.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./controller": {
      "types": "./dist/controller.d.ts",
      "default": "./dist/controller.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "default": "./dist/bridge.js"
    },
    "./registration": {
      "types": "./dist/registration.d.ts",
      "default": "./dist/registration.js"
    },
    "./singleton": {
      "types": "./dist/singleton.d.ts",
      "default": "./dist/singleton.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && cp src/global.d.ts dist/global.d.ts",
    "clean": "rm -rf dist",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/core",
    "test:coverage": "vitest run --coverage --config ../../vitest.config.ts packages/core",
    "test:watch": "vitest --config ../../vitest.config.ts packages/core",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "toolkit": {
    "bundleBudget": {
      "category": "primitive"
    }
  },
  "size-limit": [
    {
      "name": "browser",
      "path": "dist/browser.js",
      "import": "*",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "230 B"
    },
    {
      "name": "controller",
      "path": "dist/controller.js",
      "import": "*",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1.2 kB"
    },
    {
      "name": "bridge",
      "path": "dist/bridge.js",
      "import": "*",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1.1 kB"
    },
    {
      "name": "full surface",
      "path": "dist/index.js",
      "import": "*",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "3.5 kB"
    }
  ]
}
