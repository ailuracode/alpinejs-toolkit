{
  "name": "@ailuracode/alpine-core",
  "version": "0.2.2",
  "description": "Lazy plugin registry, initializer, and browser capability helpers for Alpine.js.",
  "keywords": [
    "alpine",
    "alpinejs",
    "controller",
    "headless",
    "lazy",
    "plugin",
    "registry",
    "tree-shaking"
  ],
  "homepage": "https://github.com/ailuracode/alpinejs-toolkit/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/ailuracode/alpinejs-toolkit/issues"
  },
  "license": "MIT",
  "author": "ailuracode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ailuracode/alpinejs-toolkit.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/global.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist && cp src/global.d.ts dist/global.d.ts",
    "clean": "rm -rf dist",
    "size": "size-limit",
    "test": "vitest run --config ../../vitest.config.ts packages/core",
    "test:coverage": "vitest run --coverage --config ../../vitest.config.ts packages/core",
    "test:watch": "vitest --config ../../vitest.config.ts packages/core",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "alpinejs": "^3.15.12"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@types/alpinejs": {
      "optional": true
    }
  },
  "toolkit": {
    "bundleBudget": {
      "category": "primitive"
    }
  },
  "size-limit": [
    {
      "name": "primitives (BaseController + EventEmitter + ToolkitError)",
      "path": "dist/index.js",
      "import": "{ BaseController, EventEmitter, ToolkitError }",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1 kB"
    },
    {
      "name": "guards (registration collision tracking)",
      "path": "dist/index.js",
      "import": "{ guardMagic, guardDirective, RegistrationError }",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1 kB"
    },
    {
      "name": "lifecycle bridge (controller ↔ Alpine store/magic)",
      "path": "dist/index.js",
      "import": "{ bridgeControllerStore, bridgeControllerDirective, syncRecordFromSnapshot }",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1 kB"
    },
    {
      "name": "singleton (scoped state registry)",
      "path": "dist/index.js",
      "import": "{ createSingleton, releaseSingleton, clearAllSingletons }",
      "ignore": [
        "alpinejs"
      ],
      "gzip": true,
      "brotli": true,
      "limit": "1 kB"
    }
  ]
}
