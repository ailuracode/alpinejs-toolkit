{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "types": ["@types/alpinejs", "node"],
        "noEmit": true,
        "allowImportingTsExtensions": true
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
