{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "allowJs": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@ailuracode/alpine-core/browser": ["./packages/core/src/browser.ts"],
      "@ailuracode/alpine-core/controller": ["./packages/core/src/exports/controller.ts"],
      "@ailuracode/alpine-core/bridge": ["./packages/core/src/exports/bridge.ts"],
      "@ailuracode/alpine-core/registration": ["./packages/core/src/exports/registration.ts"],
      "@ailuracode/alpine-core/singleton": ["./packages/core/src/exports/singleton.ts"],
      "@ailuracode/alpine-core/events": ["./packages/core/src/exports/events.ts"],
      "@ailuracode/alpine-core/types": ["./packages/core/src/public-types.ts"],
      "@ailuracode/alpine-core": ["./packages/core/src/index.ts"],
      "@ailuracode/alpine-plugin-registry": ["./packages/plugin-registry/src/index.ts"],
      "@ailuracode/alpine-collection": ["./packages/collection/src/index.ts"],
      "@ailuracode/alpine-ui": ["./packages/ui/src/index.ts"],
      "@ailuracode/alpine-attention": ["./packages/attention/src/index.ts"],
      "@ailuracode/alpine-calendar": ["./packages/calendar/src/index.ts"],
      "@ailuracode/alpine-child": ["./packages/child/src/index.ts"],
      "@ailuracode/alpine-dialog": ["./packages/dialog/src/index.ts"],
      "@ailuracode/alpine-menu": ["./packages/menu/src/index.ts"],
      "@ailuracode/alpine-tooltip": ["./packages/tooltip/src/index.ts"],
      "@ailuracode/alpine-tabs": ["./packages/tabs/src/index.ts"],
      "@ailuracode/alpine-accordion": ["./packages/accordion/src/index.ts"],
      "@ailuracode/alpine-command": ["./packages/command/src/index.ts"],
      "@ailuracode/alpine-carousel": ["./packages/carousel/src/index.ts"],
      "@ailuracode/alpine-virtual": ["./packages/virtual/src/index.ts"],
      "@ailuracode/alpine-selection": ["./packages/selection/src/index.ts"],
      "@ailuracode/alpine-env": ["./packages/env/src/index.ts"],
      "@ailuracode/alpine-transfer": ["./packages/transfer/src/index.ts"],
      "@ailuracode/alpine-toast": ["./packages/toast/src/index.ts"],
