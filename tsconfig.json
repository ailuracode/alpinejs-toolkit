{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@ailuracode/alpinejs-core": ["./packages/core/src/index.ts"],
      "@ailuracode/alpinejs-attention": ["./packages/attention/src/index.ts"],
      "@ailuracode/alpinejs-battery": ["./packages/battery/src/index.ts"],
      "@ailuracode/alpinejs-calendar": ["./packages/calendar/src/index.ts"],
      "@ailuracode/alpinejs-clipboard": ["./packages/clipboard/src/index.ts"],
      "@ailuracode/alpinejs-toast": ["./packages/toast/src/index.ts"],
      "@ailuracode/alpinejs-export": ["./packages/export/src/index.ts"],
      "@ailuracode/alpinejs-json-api": ["./packages/json-api/src/index.ts"],
      "@ailuracode/alpinejs-network": ["./packages/network/src/index.ts"],
      "@ailuracode/alpinejs-notify": ["./packages/notify/src/index.ts"],
      "@ailuracode/alpinejs-platform": ["./packages/platform/src/index.ts"],
      "@ailuracode/alpinejs-query": ["./packages/query/src/index.ts"],
      "@ailuracode/alpinejs-query-adapter-alpine": ["./packages/query-adapter-alpine/src/index.ts"],
      "@ailuracode/alpinejs-query-adapter-nanostores": [
        "./packages/query-adapter-nanostores/src/index.ts"
      ],
      "@ailuracode/alpinejs-query-adapter-zustand": [
        "./packages/query-adapter-zustand/src/index.ts"
      ],
      "@ailuracode/alpinejs-query-devtools": ["./packages/query-devtools/src/index.ts"],
      "@ailuracode/alpinejs-screen": ["./packages/screen/src/index.ts"],
      "@ailuracode/alpinejs-sidebar": ["./packages/sidebar/src/index.ts"],
      "@ailuracode/alpinejs-scroll": ["./packages/scroll/src/index.ts"],
      "@ailuracode/alpinejs-theme": ["./packages/theme/src/index.ts"],
      "@ailuracode/alpinejs-toggle": ["./packages/toggle/src/index.ts"],
      "@ailuracode/alpinejs-touch": ["./packages/touch/src/index.ts"],
      "@ailuracode/alpinejs-visibility": ["./packages/visibility/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.d.ts",
    "packages/*/test/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}
