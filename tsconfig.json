      "@ailuracode/alpine-keyboard": ["./packages/keyboard/src/index.ts"],
      "@ailuracode/alpine-notify": ["./packages/notify/src/index.ts"],
      "@ailuracode/alpine-overlay": ["./packages/overlay/src/index.ts"],
      "@ailuracode/alpine-permissions": ["./packages/permissions/src/index.ts"],
      "@ailuracode/alpine-query": ["./packages/query/src/index.ts"],
      "@ailuracode/alpine-query-adapter-alpine": ["./packages/query-adapter-alpine/src/index.ts"],
      "@ailuracode/alpine-query-adapter-zustand": ["./packages/query-adapter-zustand/src/index.ts"],
      "@ailuracode/alpine-query-kit/devtools": ["./packages/query-kit/src/devtools-entry.ts"],
      "@ailuracode/alpine-query-kit": ["./packages/query-kit/src/index.ts"],
      "@ailuracode/alpine-query/instrumentation": ["./packages/query/src/instrumentation-entry.ts"],
