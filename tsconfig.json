      "@ailuracode/alpine-carousel/autoplay": ["./packages/carousel/src/autoplay-entry.ts"],
      "@ailuracode/alpine-realtime/sse": ["./packages/realtime/src/entries/sse.ts"],
      "@ailuracode/alpine-realtime/websocket": ["./packages/realtime/src/entries/websocket.ts"],
      "@ailuracode/alpine-scroll/lock": ["./packages/scroll/src/entries/lock.ts"],
      "@ailuracode/alpine-scroll/navigation": ["./packages/scroll/src/entries/navigation.ts"],
      "@ailuracode/alpine-form/controller": ["./packages/form/src/entries/controller.ts"],
      "@ailuracode/alpine-form/validation": ["./packages/form/src/entries/validation.ts"],
      "@ailuracode/alpine-form/json-api": ["./packages/form/src/entries/json-api.ts"],
      "@ailuracode/alpine-form/standard-schema": ["./packages/form/src/entries/standard-schema.ts"],
      "@ailuracode/alpine-selection/controller": ["./packages/selection/src/entries/controller.ts"],
      "@ailuracode/alpine-selection/serialization": [
        "./packages/selection/src/entries/serialization.ts"
      ],
      "@ailuracode/alpine-selection/navigation": ["./packages/selection/src/entries/navigation.ts"],
      "@ailuracode/alpine-media": ["./packages/media/src/index.ts"],
      "@ailuracode/alpine-sidebar": ["./packages/sidebar/src/index.ts"],
      "@ailuracode/alpine-scroll": ["./packages/scroll/src/index.ts"],
      "@ailuracode/alpine-theme": ["./packages/theme/src/index.ts"],
      "@ailuracode/alpine-timer": ["./packages/timer/src/index.ts"],
      "@ailuracode/alpine-toggle": ["./packages/toggle/src/index.ts"],
      "@ailuracode/alpine-geo": ["./packages/geo/src/index.ts"],
      "@ailuracode/alpine-lang": ["./packages/lang/src/index.ts"],
      "@ailuracode/alpine-form": ["./packages/form/src/index.ts"],
      "@ailuracode/alpine-gesture": ["./packages/gesture/src/index.ts"],
      "@ailuracode/alpine-history": ["./packages/history/src/index.ts"],
      "@ailuracode/alpine-realtime": ["./packages/realtime/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.d.ts",
    "packages/*/test/**/*.ts",
    "packages/*/e2e/**/*.ts",
    "packages/*/playwright.config.ts",
    "e2e/**/*.ts",
    "test/**/*.ts",
    "test/**/*.d.ts",
    "vitest.config.ts",
    "scripts/repo-check.d.ts"
  ]
}
