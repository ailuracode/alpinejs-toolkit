---
import geistLatin from "@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url";
import DemoButton from "../components/astro/DemoButton.astro";
import SonnerToasts from "../components/SonnerToasts.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alpine.js Toolkit · @ailuracode",
  description = "Interactive demo of @ailuracode/alpinejs-toolkit plugins for Alpine.js",
} = Astro.props;

const pathname = Astro.url.pathname;
const isPlayground = pathname.startsWith("/playground");
const navLinkClass = (active: boolean) =>
  [
    "rounded-full px-3.5 py-1.5 text-sm font-medium transition-all duration-200 focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-[var(--ios-blue)]/50 touch-manipulation",
    active
      ? "bg-[var(--ios-blue)] text-white shadow-sm"
      : "text-[var(--ios-label-secondary)] hover:bg-[var(--ios-fill-tertiary)] hover:text-[var(--ios-label)]",
  ].join(" ");
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<script is:inline>
			(function () {
				var key = "theme";
				var saved = localStorage.getItem(key);
				var mode =
					saved === "light" || saved === "dark" || saved === "system" ? saved : "system";
				var dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
				var resolved = mode === "system" ? (dark ? "dark" : "light") : mode;
				document.documentElement.classList.toggle("dark", resolved === "dark");
				document.documentElement.style.colorScheme = resolved;
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preload" href={geistLatin} as="font" type="font/woff2" crossorigin="anonymous" />
	</head>
	<body class="min-h-screen bg-[var(--ios-bg-primary)] text-[var(--ios-label)]" x-data="demoShell" x-cloak>
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:rounded-xl focus:bg-[var(--ios-blue)] focus:px-3 focus:py-2 focus:text-white focus:outline-none"
		>
			Skip to content
		</a>

		<div class="flex min-h-screen flex-col">
			<header
				class="sticky top-0 z-30 border-b border-[var(--ios-separator)] bg-[var(--ios-bg-primary)]/80 backdrop-blur-xl backdrop-saturate-150 supports-[backdrop-filter]:bg-[var(--ios-bg-primary)]/70"
			>
				<div class="flex h-12 items-center gap-3 px-4">
				<DemoButton
					variant="ghost"
					size="icon"
						aria-label="Toggle sidebar"
						class="rounded-full text-[var(--ios-label-secondary)] hover:bg-[var(--ios-fill-tertiary)] hover:text-[var(--ios-label)]"
						x-on:click="$store.media.breakpoint === 'desktop' ? expanded = !expanded : $store.sidebar.toggle()"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="size-5"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
							stroke-width="2"
							aria-hidden="true"
						>
							<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</DemoButton>
					<div class="min-w-0 flex-1">
						<p class="truncate text-base font-semibold tracking-tight text-balance">Alpine.js Toolkit</p>
						<p class="truncate text-[11px] leading-tight text-[var(--ios-label-secondary)]">
							@ailuracode · Interactive plugin demos
						</p>
					</div>
					<nav class="hidden items-center gap-1 sm:flex" aria-label="Site">
						<a
							href="/"
							class={navLinkClass(!isPlayground)}
							aria-current={!isPlayground ? "page" : undefined}
						>
							Docs
						</a>
						<a
							href="/playground/"
							class={navLinkClass(isPlayground)}
							aria-current={isPlayground ? "page" : undefined}
						>
							Playground
						</a>
					</nav>
				</div>
			</header>

			<div class="fixed top-0 left-0 right-0 z-50 h-[2px] bg-[var(--ios-fill-quaternary)] motion-reduce:hidden" aria-hidden="true">
				<div
					class="h-full bg-[var(--ios-blue)] transition-[width] duration-100 linear motion-reduce:transition-none"
					x-bind:style="'width: ' + $store.scroll.progress + '%'"
				></div>
			</div>

			<slot />

			<SonnerToasts />
		</div>

		<script>
			import { startAlpineDemo } from "../alpine-boot";

			await startAlpineDemo();
		</script>
	</body>
</html>
