---
import DemoSidebar from "../components/DemoSidebar.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  activePlugin: string;
}

const { title, description, activePlugin } = Astro.props;

const footerLinkClass =
  "rounded-full transition-all hover:text-[var(--ios-label)] focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-[var(--ios-blue)]/50 touch-manipulation";
---

<BaseLayout title={title} description={description}>
	<DemoSidebar slot="sidebar" activePlugin={activePlugin} />

	<main
		id="main"
		tabindex="-1"
		class="min-h-[calc(100vh-3rem)] w-full flex-1 px-4 py-6 pb-[max(5rem,env(safe-area-inset-bottom))] pl-[max(1rem,env(safe-area-inset-left))] pr-[max(1rem,env(safe-area-inset-right))] transition-[margin-left,max-width] duration-300 motion-reduce:transition-none sm:px-6"
		x-bind:class="$store.media.breakpoint === 'desktop' ? (expanded ? 'ml-64 max-w-[calc(100vw-16rem)]' : 'ml-16 max-w-[calc(100vw-4rem)]') : ''"
	>
		<div class="mx-auto w-full max-w-3xl lg:max-w-5xl">
			<slot />
		</div>
	</main>

	<footer class="border-t border-[var(--ios-separator)] bg-[var(--ios-bg-primary)]">
		<div
			class="flex flex-col items-center justify-center gap-3 px-6 py-8 pb-[max(2rem,env(safe-area-inset-bottom))] text-sm text-[var(--ios-label-secondary)] transition-[margin-left,max-width] duration-300 motion-reduce:transition-none"
			x-bind:class="$store.media.breakpoint === 'desktop' ? (expanded ? 'ml-64 max-w-[calc(100vw-16rem)]' : 'ml-16 max-w-[calc(100vw-4rem)]') : ''"
		>
			<nav class="flex flex-wrap justify-center gap-x-4 gap-y-2" aria-label="Footer">
				<a href="/" class={footerLinkClass}>Documentation</a>
				<a href="/playground/" class={footerLinkClass}>Playground</a>
				<a
					href="https://github.com/ailuracode/alpinejs-toolkit"
					target="_blank"
					rel="noreferrer"
					class={footerLinkClass}
				>
					Source
					<span class="sr-only"> (opens in new tab)</span>
				</a>
				<a
					href="https://www.npmjs.com/~siddharthagf"
					target="_blank"
					rel="noreferrer"
					class={footerLinkClass}
				>
					npm
					<span class="sr-only"> (opens in new tab)</span>
				</a>
			</nav>
			<p class="text-center text-xs text-balance">
				Interactive demos for <span class="font-medium text-[var(--ios-label)]">@ailuracode</span> Alpine.js plugins
			</p>
		</div>
	</footer>
</BaseLayout>
