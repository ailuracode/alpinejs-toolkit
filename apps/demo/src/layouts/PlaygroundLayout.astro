---
import DemoSidebar from "../components/DemoSidebar.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  activePlugin: string;
}

const { title, description, activePlugin } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<main
		id="main"
		tabindex="-1"
		class="flex-1 px-4 py-6 pb-20 transition-[margin-left] duration-300 motion-reduce:transition-none sm:px-6"
		x-bind:class="$store.device.type === 'desktop' ? ($store.sidebar.collapsed ? 'ml-16' : 'ml-64') : 'mx-auto max-w-3xl'"
	>
		<slot />
	</main>

	<DemoSidebar activePlugin={activePlugin} />

	<footer class="border-t border-border bg-muted/30">
		<div
			class="flex flex-col items-center justify-center gap-3 px-6 py-8 text-sm text-muted-foreground transition-[margin-left] duration-300 motion-reduce:transition-none"
			x-bind:class="$store.device.type === 'desktop' ? ($store.sidebar.collapsed ? 'ml-16' : 'ml-64') : ''"
		>
			<nav class="flex flex-wrap justify-center gap-x-4 gap-y-2" aria-label="Footer">
				<a href="/" class="hover:text-foreground transition-colors">Documentation</a>
				<a href="/playground/" class="hover:text-foreground transition-colors">Playground</a>
				<a
					href="https://github.com/ailuracode/alpinejs-toolkit"
					target="_blank"
					rel="noreferrer"
					class="hover:text-foreground transition-colors"
				>
					Source
				</a>
				<a
					href="https://www.npmjs.com/~siddharthagf"
					target="_blank"
					rel="noreferrer"
					class="hover:text-foreground transition-colors"
				>
					npm
				</a>
			</nav>
			<p class="text-xs text-center text-balance">
				Interactive demos for <span class="font-medium text-foreground">@ailuracode</span> Alpine.js plugins
			</p>
		</div>
	</footer>
</BaseLayout>
