---
import Card, { CardContent, CardHeader, CardTitle } from "@/components/ui/card.astro";
import DemoShell from "@/demo/demo-shell.astro";
import { getPluginNavItem } from "@/plugin-nav";

const plugin = getPluginNavItem("realtime")!;
const { meta } = plugin;
---

<DemoShell plugin={plugin}>
  <Card class="border-border bg-card text-card-foreground">
    <CardHeader>
      <CardTitle class="text-base">$store.realtime</CardTitle>
    </CardHeader>
    <CardContent>
      <p class="text-sm text-muted-foreground mb-3">
        Mirrors the headless controller. Without a live endpoint, the transport stays
        <code class="rounded bg-muted px-1 py-0.5 text-xs">disconnected</code> — try
        <code class="rounded bg-muted px-1 py-0.5 text-xs">$realtime.connect()</code>
        against a real SSE / WebSocket server to see state transitions.
      </p>
      <dl
        class="grid grid-cols-2 gap-y-1 text-sm"
        x-data="realtimeDemo"
        x-init="init()"
      >
        <dt class="text-muted-foreground">status</dt>
        <dd x-text="$store.realtime.state.status"></dd>
        <dt class="text-muted-foreground">transport</dt>
        <dd x-text="$store.realtime.state.transport ?? '—'"></dd>
        <dt class="text-muted-foreground">retryCount</dt>
        <dd x-text="$store.realtime.state.retryCount"></dd>
        <dt class="text-muted-foreground">isReady</dt>
        <dd x-text="$store.realtime.isReady"></dd>
      </dl>
    </CardContent>
  </Card>
</DemoShell>

<script>
  document.addEventListener("alpine:init", () => {
    // @ts-expect-error - Alpine global on window
    window.Alpine.data("realtimeDemo", () => ({
      init() {
        // No-op: this demo only mirrors the store; consumers
        // wire $realtime.connect() from their own surfaces.
      },
    }));
  });
</script>
