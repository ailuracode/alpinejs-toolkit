---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("scroll")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<ul class="list-disc list-inside space-y-1 text-sm">
		<li>X: <strong x-text="Math.round($store.scroll.x)"></strong>px · Y: <strong x-text="Math.round($store.scroll.y)"></strong>px</li>
		<li>Direction: <strong x-text="$store.scroll.direction || '—'"></strong></li>
		<li>Progress: <strong x-text="Math.round($store.scroll.progress)"></strong>%</li>
		<li>At top: <strong x-text="$store.scroll.atTop"></strong> · At bottom: <strong x-text="$store.scroll.atBottom"></strong></li>
		<li>Locked: <strong x-text="$store.scroll.isLocked"></strong></li>
	</ul>
	<div class="flex flex-wrap gap-2 mt-3">
		<DemoButton @click="$store.scroll.lock()">lock()</DemoButton>
		<DemoButton @click="$store.scroll.lock({ axis: 'both' })">lock(both)</DemoButton>
		<DemoButton @click="$store.scroll.unlock()">unlock()</DemoButton>
		<DemoButton @click="$store.scroll.toggleLock()">toggleLock()</DemoButton>
		<DemoButton x-show="$store.scroll.showToTop" x-cloak @click="$store.scroll.toTop()">toTop()</DemoButton>
		<DemoButton @click="$store.scroll.toBottom()">toBottom()</DemoButton>
		<DemoButton @click="$store.scroll.refresh()">refresh()</DemoButton>
	</div>
	<p class="text-sm text-muted-foreground mt-3">
		Sticky progress bar in the header uses <code>$store.scroll.progress</code>. Mobile sidebar open also locks scroll via <code>onOpen</code> in <code>plugin-registry.ts</code>.
	</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
