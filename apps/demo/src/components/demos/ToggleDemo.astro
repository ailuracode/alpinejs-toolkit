---
import { getPluginNavItem } from "../../plugin-nav";
import Badge from "../astro/Badge.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("toggle")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-6">
		<div x-data="{ toggle: $toggle({ states: { on: true, off: false }, initial: false }) }">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Puppy — boolean</p>
			<p class="mt-1">Value: <strong x-text="toggle.value"></strong></p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle.toggle()">toggle()</DemoButton>
				<DemoButton @click="toggle.set(true)">set(true)</DemoButton>
				<DemoButton @click="toggle.set(false)">set(false)</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2">
				Puppy tier: <code>@ailuracode/alpine-toggle/puppy</code> registers <code>$toggle(initial?)</code> — same reactive shell, boolean-only factory.
			</p>
		</div>

		<div
			x-data={`{
				toggle: $toggle({ states: { on: 'enabled', off: 'disabled', indeterminate: 'mixed' }, initial: 'mixed' }),
				lastChange: '',
				previous: null,
				init() {
					this.$watch('toggle.value', (value) => {
						if (this.previous !== null) {
							this.lastChange = String(this.previous) + ' → ' + String(value);
						}
						this.previous = value;
					});
				},
			}`}
		>
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Doggo — custom states</p>
			<p class="mt-1">
				Value: <strong x-text="toggle.value"></strong>
				<Badge
					variant="outline"
					class="ml-2 border-amber-500/50 bg-amber-500/10 text-amber-700 dark:text-amber-400"
					x-show="toggle.is(toggle.states.indeterminate)"
				>mixed</Badge>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle.toggle()">toggle()</DemoButton>
				<DemoButton @click="toggle.next()">next()</DemoButton>
				<DemoButton @click="toggle.reset()">reset()</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2" x-show="lastChange">
				Value trail: <span x-text="lastChange"></span>
			</p>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-1">
				Doggo tier adds <code>onChange()</code> on <code>createToggle</code> — here <code>$watch('toggle.value')</code> mirrors the same idea in Alpine.
			</p>
		</div>

		<div x-data="{ toggle: $toggle({ states: { on: 'yes', off: 'no' }, initial: 'no' }) }">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Big Dog — binary</p>
			<p class="mt-1">Value: <strong x-text="toggle.value"></strong></p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle.toggle()">toggle()</DemoButton>
				<DemoButton @click="toggle.next()">next()</DemoButton>
				<DemoButton @click="toggle.reset()">reset()</DemoButton>
				<Badge
					x-bind:class="{ 'bg-[var(--ios-blue)] text-white': toggle.is(toggle.states.on), 'text-[var(--ios-label-secondary)]': toggle.is(toggle.states.off) }"
					x-text="toggle.value"
				></Badge>
			</div>
		</div>

		<div x-data="{ toggle: $toggle({ states: { on: 'yes', off: 'no', indeterminate: 'unknown' }, initial: 'unknown' }) }">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Big Dog — ternary</p>
			<p class="mt-1">
				Value: <strong x-text="toggle.value"></strong>
				<Badge
					variant="outline"
					class="ml-2 border-amber-500/50 bg-amber-500/10 text-amber-700 dark:text-amber-400"
					x-show="toggle.is(toggle.states.indeterminate)"
				>neutral</Badge>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle.toggle()">toggle()</DemoButton>
				<DemoButton @click="toggle.next()">next()</DemoButton>
				<DemoButton @click="toggle.reset()">reset()</DemoButton>
				<DemoButton @click="toggle.set(toggle.states.indeterminate)">set(unknown)</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2">
				Root import <code>@ailuracode/alpine-toggle</code> — typed <code>on('change')</code>, lifecycle, and hydration on <code>createToggle</code>.
			</p>
		</div>
	</div>
	<p class="text-xs text-[var(--ios-label-secondary)] mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
