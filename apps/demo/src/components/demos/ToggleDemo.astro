---
import { getPluginNavItem } from "../../plugin-nav";
import Badge from "../astro/Badge.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("toggle")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-6">
		<div x-data="togglePuppyDemo">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Puppy — boolean</p>
			<p class="mt-1">Lamp: <strong x-text="value"></strong></p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle()">toggle()</DemoButton>
				<DemoButton @click="setTrue()">set(true)</DemoButton>
				<DemoButton @click="setFalse()">set(false)</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2">
				Import <code>@ailuracode/alpine-toggle/puppy</code> — <code>$toggle(initial?)</code> with no state config.
			</p>
		</div>

		<div x-data="toggleDoggoDemo">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Doggo — custom states</p>
			<p class="mt-1">
				Filter: <strong x-text="value"></strong>
				<Badge
					variant="outline"
					class="ml-2 border-amber-500/50 bg-amber-500/10 text-amber-700 dark:text-amber-400"
					x-show="is(states.indeterminate)"
				>mixed</Badge>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle()">toggle()</DemoButton>
				<DemoButton @click="next()">next()</DemoButton>
				<DemoButton @click="reset()">reset()</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2" x-show="lastChange">
				Last <code>onChange</code>: <span x-text="lastChange"></span>
			</p>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-1">
				Import <code>@ailuracode/alpine-toggle/doggo</code> — lightweight subscriptions without lifecycle APIs.
			</p>
		</div>

		<div x-data="toggleBinaryDemo">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Big Dog — binary</p>
			<p class="mt-1">Power: <strong x-text="value"></strong></p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle()">toggle()</DemoButton>
				<DemoButton @click="next()">next()</DemoButton>
				<DemoButton @click="reset()">reset()</DemoButton>
				<Badge
					x-bind:class="{ 'bg-[var(--ios-blue)] text-white': is(states.on), 'text-[var(--ios-label-secondary)]': is(states.off) }"
					x-text="value"
				></Badge>
			</div>
		</div>

		<div x-data="toggleTernaryDemo">
			<p class="text-xs font-medium uppercase tracking-wide text-[var(--ios-label-secondary)]">Big Dog — ternary</p>
			<p class="mt-1">
				Answer: <strong x-text="value"></strong>
				<Badge
					variant="outline"
					class="ml-2 border-amber-500/50 bg-amber-500/10 text-amber-700 dark:text-amber-400"
					x-show="is(states.indeterminate)"
				>neutral</Badge>
			</p>
			<div class="flex flex-wrap gap-2 mt-2">
				<DemoButton @click="toggle()">toggle()</DemoButton>
				<DemoButton @click="next()">next()</DemoButton>
				<DemoButton @click="reset()">reset()</DemoButton>
				<DemoButton @click="setUnknown()">set(unknown)</DemoButton>
			</div>
			<p class="text-xs text-[var(--ios-label-secondary)] mt-2">
				Root import <code>@ailuracode/alpine-toggle</code> — typed <code>on('change')</code>, lifecycle, and hydration.
			</p>
		</div>
	</div>
	<p class="text-xs text-[var(--ios-label-secondary)] mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
