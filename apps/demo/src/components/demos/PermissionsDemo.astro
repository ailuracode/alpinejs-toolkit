---
import { getPluginNavItem } from "../../plugin-nav";
import Alert from "../astro/Alert.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("permissions")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="space-y-4 text-sm">
		<template x-for="name in ['notifications', 'geolocation', 'idle-detection']" :key="name">
			<div class="rounded-md border border-border p-3">
				<p class="font-medium" x-text="name"></p>
				<ul class="list-disc list-inside mt-2 space-y-1">
					<li>Permission: <strong x-text="$permissions.registry[name]?.permission ?? 'unknown'"></strong></li>
					<li>Availability: <strong x-text="$permissions.registry[name]?.availability ?? 'unknown'"></strong></li>
					<li>Can request: <strong x-text="$permissions.registry[name]?.canRequest ?? false"></strong></li>
				</ul>
				<div class="flex flex-wrap gap-2 mt-3">
					<DemoButton @click="await $permissions.query(name)">query()</DemoButton>
					<DemoButton
						x-show="$permissions.registry[name]?.canRequest"
						x-cloak
						@click="await $permissions.request(name)"
					>
						request()
					</DemoButton>
				</div>
				<Alert
					variant="destructive"
					class="mt-3"
					x-show="$permissions.registry[name]?.permission === 'denied'"
					x-cloak
				>
					<span>Permission denied — adjust browser or OS settings to recover access.</span>
				</Alert>
			</div>
		</template>
	</div>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
