---
import { getPluginNavItem } from "../../plugin-nav";
import Alert from "../astro/Alert.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("battery")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<template x-if="$battery.isAvailable">
		<div>
			<div class="flex items-center gap-3 mb-3" aria-hidden="true">
				<div class="battery-shell">
					<div
						class="battery-fill"
						x-bind:class="{
							'bg-amber-500': $battery.level < 0.2 && !$battery.isCharging,
							'bg-primary': $battery.isCharging,
							'bg-green-500': $battery.level >= 0.2 && !$battery.isCharging,
						}"
						x-bind:style="'width: ' + Math.round($battery.level * 100) + '%'"
					></div>
				</div>
				<span class="font-semibold tabular-nums" x-text="Math.round($battery.level * 100) + '%'"></span>
			</div>
			<p
				class="font-semibold"
				x-bind:class="$battery.isCharging ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400'"
				x-text="$battery.isCharging ? 'Charging' : 'On battery'"
			></p>
			<ul class="list-disc list-inside space-y-1 mt-2">
				<li x-show="$battery.chargingTime !== null">
					Time to full:
					<strong x-text="Math.round($battery.chargingTime / 60) + ' min'"></strong>
				</li>
				<li x-show="$battery.dischargingTime !== null">
					Time to empty:
					<strong x-text="Math.round($battery.dischargingTime / 60) + ' min'"></strong>
				</li>
			</ul>
			<Alert variant="warning" class="mt-3" x-show="$battery.level < 0.2 && !$battery.isCharging" x-cloak>
				<span>Low battery — consider plugging in your device.</span>
			</Alert>
		</div>
	</template>
	<p class="text-sm text-muted-foreground" x-show="!$battery.isAvailable" x-cloak>
		Battery status is not available on this device or browser.
	</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
