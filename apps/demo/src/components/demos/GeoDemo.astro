---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("geo")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p class="text-sm text-muted-foreground" x-show="!$store.geo.isSupported" x-cloak>
		Geolocation is not available in this browser.
	</p>
	<template x-if="$store.geo.isSupported">
		<div>
			<div class="flex flex-wrap gap-2 mt-1">
				<DemoButton @click="$store.geo.request({ enableHighAccuracy: true, timeout: 10000 })" x-bind:disabled="$store.geo.isLoading">
					<span x-text="$store.geo.isLoading ? 'Locating…' : 'request()'"></span>
				</DemoButton>
				<DemoButton x-show="!$store.geo.isWatching" x-cloak @click="$store.geo.watch()">watch()</DemoButton>
				<DemoButton x-show="$store.geo.isWatching" x-cloak @click="$store.geo.unwatch()">unwatch()</DemoButton>
				<DemoButton @click="$store.geo.reset()">reset()</DemoButton>
			</div>
			<ul class="list-disc list-inside space-y-1 text-sm mt-3" x-show="$store.geo.hasPosition" x-cloak>
				<li>Lat: <strong x-text="$store.geo.latitude?.toFixed(4)"></strong> · Lng: <strong x-text="$store.geo.longitude?.toFixed(4)"></strong></li>
				<li>Accuracy: ±<strong x-text="Math.round($store.geo.accuracy ?? 0)"></strong> m</li>
				<li x-show="$store.geo.altitude !== null">Altitude: <strong x-text="$store.geo.altitude?.toFixed(1)"></strong> m</li>
				<li x-show="$store.geo.speed !== null">Speed: <strong x-text="$store.geo.speed?.toFixed(1)"></strong> m/s</li>
			</ul>
			<p class="text-sm text-destructive mt-2" x-show="$store.geo.hasError" x-cloak>
				<strong x-text="$store.geo.error"></strong>
				<span x-show="$store.geo.errorCode !== null"> (code <span x-text="$store.geo.errorCode"></span>)</span>
			</p>
		</div>
	</template>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
