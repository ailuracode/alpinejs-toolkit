---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("touch")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<ul class="list-disc list-inside space-y-1 text-sm">
		<li>Touch: <strong x-text="$touch.isTouch"></strong></li>
		<li>Coarse pointer: <strong x-text="$touch.isCoarse"></strong></li>
		<li>Fine pointer: <strong x-text="$touch.isFine"></strong></li>
		<li>Hover: <strong x-text="$touch.canHover"></strong></li>
		<li>Max touch points: <strong x-text="$touch.maxTouchPoints"></strong></li>
	</ul>
	<p class="text-sm text-muted-foreground mt-3" x-show="$touch.canHover" x-cloak>Hover tooltips enabled.</p>
	<p class="text-sm text-muted-foreground mt-3" x-show="!$touch.canHover" x-cloak>Touch-first UI — enlarge tap targets.</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
