---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("toast")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-4">
		<div>
			<p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2">Variants</p>
			<div class="flex flex-wrap gap-2">
				<DemoButton @click="$toast('Hello from Alpine!')">Default</DemoButton>
				<DemoButton @click="$toast.success('Saved')">Success</DemoButton>
				<DemoButton @click="$toast.info({ title: 'Heads up', description: 'Title + description fields' })">Info</DemoButton>
				<DemoButton @click="$toast.warning('Careful')">Warning</DemoButton>
				<DemoButton variant="destructive" @click="$toast.error('Failed')">Error</DemoButton>
				<DemoButton @click="$toast.loading('Uploading…')">Loading</DemoButton>
			</div>
		</div>

		<div>
			<p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2">Position & Content</p>
			<div class="flex flex-wrap gap-2">
				<DemoButton @click="$toast('Top center', { position: 'top-center' })">Top Center</DemoButton>
				<DemoButton @click="$toast.info({ content: { kind: 'badge', label: 'Pro plan', seats: 3 } })">Custom Content</DemoButton>
				<DemoButton @click="$toast.warning({ title: 'File deleted', duration: false, action: { label: 'Undo' }, content: { kind: 'undo-demo' } })">Undo Action</DemoButton>
			</div>
		</div>

		<div>
			<p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2">Queue API</p>
			<div class="flex flex-wrap gap-2" x-data="{ lastToastId: null }">
				<DemoButton @click="$toast.pushUnique('sync', { title: 'Syncing…', variant: 'loading', duration: false })">pushUnique</DemoButton>
				<DemoButton @click="$toast.fromPayload({ title: 'Flash message', variant: 'success', description: 'fromPayload()' })">fromPayload</DemoButton>
				<DemoButton @click="lastToastId = $toast.info('Will update…'); setTimeout(function () { $toast.update(lastToastId, { title: 'Updated in place', variant: 'success' }) }, 1200)">update()</DemoButton>
				<DemoButton @click="$toast.dismissAt('top-center')">dismissAt top-center</DemoButton>
				<DemoButton @click="$toast.dismissAll()">dismissAll</DemoButton>
				<DemoButton @click="for (var i = 0; i < 5; i++) { $toast('Toast ' + (i + 1)) }">Flood Stack (5)</DemoButton>
			</div>
		</div>

		<div>
			<p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2">Promise</p>
			<div class="flex flex-wrap gap-2">
				<DemoButton @click="$toast.promise(function () { return new Promise(function (r) { setTimeout(function () { r('done') }, 1200) }) }, { loading: 'Saving…', success: 'Saved!', error: 'Failed' })">
					Resolve
				</DemoButton>
				<DemoButton variant="destructive" @click="$toast.promise(function () { return Promise.reject(new Error('nope')) }, { loading: 'Saving…', success: 'Saved!', error: 'Could not save' })">
					Reject
				</DemoButton>
			</div>
		</div>

		<div>
			<p class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-2">Window Event</p>
			<DemoButton
				@click="window.dispatchEvent(new CustomEvent('toast', { detail: { title: 'From window event', variant: 'info' } }))"
			>
				Dispatch Toast Event
			</DemoButton>
		</div>
	</div>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code> · Renderer: <code>SonnerToasts.astro</code>
	</p>
</DemoSection>
