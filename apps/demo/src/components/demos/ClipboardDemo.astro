---
import { getPluginNavItem } from "../../plugin-nav";
import Alert from "../astro/Alert.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("clipboard")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div
		x-data="{
			status: 'idle',
			async copy(text, mode) {
				try {
					await $clipboard(text, mode ? { mode } : undefined);
					this.status = 'success';
				} catch {
					this.status = 'error';
				}
				setTimeout(() => { this.status = 'idle' }, 2000);
			}
		}"
	>
		<div class="flex flex-wrap gap-2">
			<DemoButton @click="copy('Hello from Alpine!')">Copy text (auto)</DemoButton>
			<DemoButton @click="copy(window.location.href)">Copy page URL</DemoButton>
			<DemoButton @click="copy('Legacy copy path', 'legacy')">legacy mode</DemoButton>
		</div>
		<Alert variant="success" class="mt-3" x-show="status === 'success'" x-cloak>
			<span>Copied to clipboard!</span>
		</Alert>
		<Alert variant="destructive" class="mt-3" x-show="status === 'error'" x-cloak>
			<span>Copy failed — try again from a click handler.</span>
		</Alert>
	</div>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
