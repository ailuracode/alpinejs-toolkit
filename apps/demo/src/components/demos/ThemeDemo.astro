---
import { segmentButtonActiveClass } from "../../lib/button-styles";
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("theme")!;

const themeBtnActive = segmentButtonActiveClass;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<ul class="list-disc list-inside space-y-1 text-sm">
		<li>Preference (current): <strong x-text="$store.theme.current"></strong></li>
		<li>System: <strong x-text="$store.theme.system"></strong></li>
		<li>Resolved: <strong x-text="$store.theme.resolved"></strong></li>
	</ul>
	<div class="flex flex-wrap gap-2 mt-3">
		<DemoButton class={themeBtnActive} x-bind:data-active="$store.theme.current === 'light' ? 'true' : null" @click="$store.theme.set('light')">Light</DemoButton>
		<DemoButton class={themeBtnActive} x-bind:data-active="$store.theme.current === 'dark' ? 'true' : null" @click="$store.theme.set('dark')">Dark</DemoButton>
		<DemoButton class={themeBtnActive} x-bind:data-active="$store.theme.current === 'system' ? 'true' : null" @click="$store.theme.set('system')">System</DemoButton>
		<DemoButton @click="$store.theme.toggle()">toggle()</DemoButton>
		<DemoButton @click="$store.theme.reset()">reset()</DemoButton>
	</div>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>