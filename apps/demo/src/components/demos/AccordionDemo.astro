---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("accordion")!;
const triggerClasses =
  "flex w-full items-center justify-between rounded-md border px-4 py-3 text-left text-sm font-medium hover:bg-accent";
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-10 max-w-lg">
		<div
			x-data="{ items: ['billing', 'shipping', 'returns'] }"
			x-init="
				$store.accordion.register('single-default', {
					mode: 'single',
					defaultOpen: 'shipping',
				});
				items.forEach(id => $store.accordion.registerItem('single-default', id));
			"
			@keydown="$store.accordion.handleKeydown('single-default', $event)"
		>
			<h3 class="text-sm font-medium mb-2">Single mode · default open</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Mode: <strong>single</strong> · Open:
				<strong x-text="$store.accordion.openIds('single-default').join(', ') || '—'"></strong>
			</p>

			<div class="space-y-2">
				<template x-for="id in items" :key="id">
					<div>
						<button
							type="button"
							class={triggerClasses}
							x-bind="$store.accordion.triggerProps('single-default', id)"
							@click="$store.accordion.toggle('single-default', id)"
						>
							<span x-text="id"></span>
							<span x-text="$store.accordion.isOpen('single-default', id) ? '−' : '+'"></span>
						</button>
						<div
							class="overflow-hidden"
							x-show="$store.accordion.isOpen('single-default', id)"
							x-collapse
							x-bind="$store.accordion.panelProps('single-default', id)"
						>
							<div class="px-4 py-3 text-sm text-muted-foreground">
								Only one panel stays open. <code>defaultOpen: 'shipping'</code> expands on init.
							</div>
						</div>
					</div>
				</template>
			</div>
		</div>

		<div
			x-data="{ items: ['overview', 'features', 'pricing'] }"
			x-init="
				$store.accordion.register('single', { mode: 'single' });
				items.forEach(id => $store.accordion.registerItem('single', id));
			"
			@keydown="$store.accordion.handleKeydown('single', $event)"
		>
			<h3 class="text-sm font-medium mb-2">Single mode · collapsed</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Open:
				<strong x-text="$store.accordion.openIds('single').join(', ') || '—'"></strong>
			</p>

			<div class="space-y-2">
				<template x-for="id in items" :key="id">
					<div>
						<button
							type="button"
							class={triggerClasses}
							x-bind="$store.accordion.triggerProps('single', id)"
							@click="$store.accordion.toggle('single', id)"
						>
							<span x-text="id"></span>
							<span x-text="$store.accordion.isOpen('single', id) ? '−' : '+'"></span>
						</button>
						<div
							class="overflow-hidden"
							x-show="$store.accordion.isOpen('single', id)"
							x-collapse
							x-bind="$store.accordion.panelProps('single', id)"
						>
							<div class="px-4 py-3 text-sm text-muted-foreground">
								Opening another panel closes the previous one.
							</div>
						</div>
					</div>
				</template>
			</div>
		</div>

		<div
			x-data="{ items: ['notifications', 'privacy', 'integrations'] }"
			x-init="
				$store.accordion.register('multiple-default', {
					mode: 'multiple',
					defaultOpen: ['notifications', 'integrations'],
				});
				items.forEach(id => $store.accordion.registerItem('multiple-default', id));
			"
			@keydown="$store.accordion.handleKeydown('multiple-default', $event)"
		>
			<h3 class="text-sm font-medium mb-2">Multiple mode · default open</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Mode: <strong>multiple</strong> · Open:
				<strong x-text="$store.accordion.openIds('multiple-default').join(', ') || '—'"></strong>
			</p>

			<div class="space-y-2">
				<template x-for="id in items" :key="id">
					<div>
						<button
							type="button"
							class={triggerClasses}
							x-bind="$store.accordion.triggerProps('multiple-default', id)"
							@click="$store.accordion.toggle('multiple-default', id)"
						>
							<span x-text="id"></span>
							<span x-text="$store.accordion.isOpen('multiple-default', id) ? '−' : '+'"></span>
						</button>
						<div
							class="overflow-hidden"
							x-show="$store.accordion.isOpen('multiple-default', id)"
							x-collapse
							x-bind="$store.accordion.panelProps('multiple-default', id)"
						>
							<div class="px-4 py-3 text-sm text-muted-foreground">
								Several panels can stay open. Defaults:
								<code>['notifications', 'integrations']</code>.
							</div>
						</div>
					</div>
				</template>
			</div>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Accessibility</h3>
			<p class="text-xs text-muted-foreground">
				<code>triggerProps()</code> sets <code>aria-expanded</code> and roving <code>tabindex</code>.
				Arrow keys move between triggers when the group is focused. Animate panels with the official
				<a href="https://alpinejs.dev/plugins/collapse" class="underline hover:text-foreground">@alpinejs/collapse</a>
				plugin — <code>x-show</code> + <code>x-collapse</code> on the same element.
			</p>
		</div>
	</div>

	<p class="text-xs text-muted-foreground mt-6">Package: <code>{plugin.package}</code></p>
</DemoSection>
