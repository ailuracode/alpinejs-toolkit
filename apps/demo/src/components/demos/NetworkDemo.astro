---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("network")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p
		class="font-semibold"
		x-bind:class="$network.isOnline ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400'"
		x-text="$network.isOnline ? 'Online' : 'Offline'"
	></p>
	<ul class="list-disc list-inside space-y-1 text-sm mt-2">
		<li>isOnline: <strong x-text="$network.isOnline"></strong></li>
		<li>isOffline: <strong x-text="$network.isOffline"></strong></li>
	</ul>
	<div class="flex flex-wrap gap-2 mt-3">
		<DemoButton x-bind:disabled="!$network.isOnline">Save (requires connection)</DemoButton>
	</div>
	<p class="text-sm text-amber-600 dark:text-amber-400 mt-3" x-show="$network.isOffline" x-cloak>
		Offline banner pattern — disable sync until back online.
	</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
