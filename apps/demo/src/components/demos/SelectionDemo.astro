---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("selection")!;
const itemClass = "cursor-pointer rounded-md border px-3 py-2 text-sm";
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div
		class="grid min-w-0 gap-8"
		x-data="{
			items: ['Alpha', 'Bravo', 'Charlie', 'Delta', 'Echo'],
			disabled: ['Charlie'],
			mode: 'multiple',
			initSelection() {
				$store.selection.create('demo', {
					mode,
					keys: items,
					disabledKeys: disabled,
				});
			},
			selectedLabel() {
				const snap = $store.selection.instances.demo;
				if (!snap) return '—';
				return snap.selectedKeys.join(', ') || 'none';
			},
			itemClass(key) {
				const selected = $store.selection.isSelected('demo', key);
				const active = $store.selection.isActive('demo', key);
				return [
					'${itemClass}',
					selected ? 'border-primary bg-primary/10' : 'border-border',
					active ? 'ring-2 ring-primary/40' : '',
					!$store.selection.isSelectable('demo', key) ? 'opacity-50 cursor-not-allowed' : '',
				].join(' ');
			},
			onClick(event, key) {
				if (!$store.selection.isSelectable('demo', key)) return;
				if (event.shiftKey) {
					$store.selection.extend('demo', key);
					return;
				}
				if (event.metaKey || event.ctrlKey) {
					$store.selection.toggle('demo', key);
					return;
				}
				$store.selection.replace('demo', key);
			},
			setMode(next) {
				mode = next;
				$store.selection.setMode('demo', next);
			},
		}"
		x-init="initSelection()"
	>
		<div class="flex flex-wrap items-center gap-2 text-xs">
			<span class="text-muted-foreground">Mode</span>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('single')">Single</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('multiple')">Multiple</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('range')">Range</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="$store.selection.selectAll('demo')">Select all</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="$store.selection.clear('demo')">Clear</button>
		</div>

		<p class="text-xs text-muted-foreground">
			Click to replace, Ctrl/Cmd+click to toggle, Shift+click to extend. Charlie is disabled.
		</p>
		<p class="text-xs font-mono" x-text="`Selected: ${selectedLabel()}`"></p>

		<ul class="grid gap-2 sm:grid-cols-2" x-bind="$store.selection.listProps('demo', { label: 'Selection demo' })">
			<template x-for="item in items" :key="item">
				<li
					x-bind="{ ...$store.selection.itemProps('demo', item), class: itemClass(item) }"
					@click="onClick($event, item)"
					x-text="item"
				></li>
			</template>
		</ul>
	</div>
</DemoSection>
