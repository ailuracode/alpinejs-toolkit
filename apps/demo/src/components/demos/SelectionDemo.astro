---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("selection")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid min-w-0 gap-8" x-data="selectionDemo">
		<div class="flex flex-wrap items-center gap-2 text-xs">
			<span class="text-muted-foreground">Mode</span>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('single')">Single</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('multiple')">Multiple</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="setMode('range')">Range</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="$store.selection.selectAll('demo')">Select all</button>
			<button type="button" class="rounded-md border px-2 py-1" @click="$store.selection.clear('demo')">Clear</button>
		</div>

		<p class="text-xs text-muted-foreground">
			Click to replace, Ctrl/Cmd+click to toggle, Shift+click to extend. Charlie is disabled.
		</p>
		<p
			class="text-xs font-mono"
			x-text="`Selected: ${$store.selection.instances.demo?.selectedKeys.join(', ') || 'none'}`"
		></p>
		<p class="text-xs text-muted-foreground" x-show="$store.selection.instances.demo">
			Mode:
			<span class="font-mono" x-text="$store.selection.instances.demo?.mode"></span>
			· Active:
			<span class="font-mono" x-text="$store.selection.instances.demo?.activeKey ?? '—'"></span>
		</p>

		<div class="flex items-center gap-2 text-xs">
			<span class="text-muted-foreground">Serialized:</span>
			<code class="rounded bg-muted px-1.5 py-0.5 font-mono" x-text="serialized() || '—'"></code>
			<button type="button" class="rounded-md border px-2 py-1 text-xs" @click="copyUrl()">Copy URL</button>
		</div>

		<ul class="grid gap-2 sm:grid-cols-2" x-bind="$store.selection.listProps('demo', { label: 'Selection demo' })">
			<template x-for="item in items" :key="item">
				<li role="presentation">
					<button
						type="button"
						x-bind="$store.selection.itemProps('demo', item)"
						:class="itemClass(item)"
						:disabled="$store.selection.instances.demo?.disabledKeys.includes(item)"
						@click="pick($event, item)"
						x-text="item"
					></button>
				</li>
			</template>
		</ul>
	</div>
</DemoSection>
