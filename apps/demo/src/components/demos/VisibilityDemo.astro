---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("visibility")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p
		class="font-semibold"
		x-bind:class="$visibility.isVisible ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400'"
		x-text="$visibility.isVisible ? 'Tab visible' : 'Tab hidden'"
	></p>
	<ul class="list-disc list-inside space-y-1 text-sm">
		<li>State: <strong x-text="$visibility.state"></strong></li>
		<li>isHidden: <strong x-text="$visibility.isHidden"></strong></li>
		<li>is('hidden'): <strong x-text="$visibility.is('hidden')"></strong></li>
	</ul>
	<p class="text-sm text-muted-foreground mt-2" x-show="$visibility.isHidden" x-cloak>
		Pause expensive animations while the tab is hidden.
	</p>
	<p class="text-sm text-muted-foreground mt-2">Switch tabs to see live updates.</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
