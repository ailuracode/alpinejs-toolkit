---
import { getPluginNavItem } from "../../plugin-nav";
import Badge from "../astro/Badge.astro";
import Kbd from "../astro/Kbd.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("platform")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p>
		Detected OS: <strong x-text="$platform.name"></strong> · is(macos):
		<strong x-text="$platform.is('macos')"></strong>
	</p>
	<div class="flex flex-wrap gap-2 mt-2">
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $platform.isMac }">macOS</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $platform.isWindows }">Windows</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $platform.isLinux }">Linux</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $platform.isIos }">iOS</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $platform.isAndroid }">Android</Badge>
	</div>
	<p class="text-sm text-muted-foreground mt-2" x-show="$platform.isMac" x-cloak>
		Use <Kbd>⌘</Kbd> + <Kbd>C</Kbd> to copy.
	</p>
	<p class="text-sm text-muted-foreground mt-2" x-show="$platform.isWindows || $platform.isLinux" x-cloak>
		Use <Kbd>Ctrl</Kbd> + <Kbd>C</Kbd> to copy.
	</p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
