---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";
import PokeapiQueryDemo from "../PokeapiQueryDemo.astro";
import QueryAdvancedDemo from "../QueryAdvancedDemo.astro";

const plugin = getPluginNavItem("query")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p class="text-sm text-muted-foreground text-pretty">
		Three adapters — pick one for <code class="rounded bg-muted px-1 py-0.5 font-mono text-xs">query(&#123; adapter &#125;)</code>.
		Each card runs the same paginated PokeAPI demo. Use <strong>Invalidate</strong>, <strong>Prefetch Next</strong>, and
		<strong>Remove Cache</strong> to exercise the cache API. Open <strong>Query Devtools</strong> (bottom-right) to inspect observers.
	</p>
	<div class="grid gap-4">
		<PokeapiQueryDemo dataName="queryNanostoresAdapterDemo" title="Nanostores" badgeClass="bg-primary text-primary-foreground" />
		<PokeapiQueryDemo dataName="queryAlpineAdapterDemo" title="Alpine.reactive" />
		<PokeapiQueryDemo dataName="queryZustandAdapterDemo" title="Zustand" />
	</div>
	<QueryAdvancedDemo />
	<p class="text-xs text-muted-foreground mt-3">
		Packages: <code>{plugin.package}</code>,
		<code>@ailuracode/alpine-query-adapter-nanostores</code>,
		<code>@ailuracode/alpine-query-adapter-alpine</code>,
		<code>@ailuracode/alpine-query-adapter-zustand</code>,
		<code>@ailuracode/alpine-query-devtools</code>
	</p>
</DemoSection>
