---
import { getPluginNavItem } from "../../plugin-nav";
import Alert from "../astro/Alert.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("attention")!;
---

<DemoSection id={plugin.id} description={plugin.description}>
	<span slot="title">
		{plugin.title}
		<code class="text-muted-foreground font-normal ml-1.5">$wakelock</code>
		<span class="text-muted-foreground font-normal">·</span>
		<code class="text-muted-foreground font-normal">$idle</code>
	</span>
	<div class="flex flex-wrap gap-2 mt-1">
		<DemoButton x-show="$wakelock.isSupported" x-cloak @click="$wakelock.isActive ? $wakelock.release() : $wakelock.request()" x-bind:disabled="$wakelock.isRequesting">
			<span x-text="$wakelock.isActive ? 'release()' : 'request()'"></span>
		</DemoButton>
		<DemoButton x-show="$idle.isSupported && $idle.permission !== 'granted' && !$idle.isWatching" x-cloak @click="await $idle.requestPermission()" x-bind:disabled="$idle.isLoading">
			requestPermission()
		</DemoButton>
		<DemoButton x-show="$idle.isSupported && $idle.permission === 'granted' && !$idle.isWatching" x-cloak @click="await $idle.start({ threshold: 120000 })" x-bind:disabled="$idle.isLoading">
			start(2 min threshold)
		</DemoButton>
		<DemoButton x-show="$idle.isWatching" x-cloak @click="$idle.stop()">stop()</DemoButton>
	</div>
	<Alert variant="warning" class="mt-3" x-show="$idle.isIdle" x-cloak>
		User is idle — pause expensive work.
	</Alert>
	<ul class="list-disc list-inside space-y-1 mt-3 text-sm">
		<li>Wake lock: <strong x-text="$wakelock.isSupported ? ($wakelock.isActive ? 'active' : 'inactive') : 'unsupported'"></strong></li>
		<li x-show="$idle.isSupported" x-cloak>Idle permission: <strong x-text="$idle.permission ?? 'unknown'"></strong></li>
		<li x-show="$idle.isWatching" x-cloak>User: <strong x-text="$idle.userState"></strong> · Screen: <strong x-text="$idle.screenState"></strong> · isIdle: <strong x-text="$idle.isIdle"></strong></li>
	</ul>
	<p class="text-sm text-destructive mt-2" x-show="$wakelock.error" x-cloak x-text="$wakelock.error"></p>
	<p class="text-sm text-destructive mt-2" x-show="$idle.error" x-cloak x-text="$idle.error"></p>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code> — for tab visibility use <code>@ailuracode/alpine-env</code> (<code>$visibility</code>).
	</p>
</DemoSection>
