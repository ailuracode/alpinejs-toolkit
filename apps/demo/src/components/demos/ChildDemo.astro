---
import { cn } from "@/lib/utils";
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("child")!;
const linkClasses =
  "inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90";
const buttonClasses =
  "inline-flex items-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent";
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-6">
		<div x-data="{ clicks: 0 }">
			<h3 class="text-sm font-medium mb-2">asChild-style link</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Wrapper classes and click behavior land on the anchor; the <code>&lt;span&gt;</code> is removed.
			</p>
			<span x-child class={linkClasses} @click="clicks++">
				<a href="/docs/plugins/child/" class="no-underline text-inherit"> Ir a docs </a>
			</span>
			<p class="text-xs text-muted-foreground mt-2">
				Clicks: <strong x-text="clicks"></strong>
			</p>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Class merge</h3>
			<span x-child class="btn ring-2 ring-primary/30">
				<button type="button" class={cn(buttonClasses, "custom-child")}>Open</button>
			</span>
			<p class="text-xs text-muted-foreground mt-2">
				Inspect the button — child classes are kept and wrapper tokens are appended.
			</p>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Style merge</h3>
			<span x-child style="outline: 2px dashed hsl(var(--primary)); outline-offset: 4px;">
				<button type="button" class={buttonClasses} style="font-weight: 600;">Styled child</button>
			</span>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">aria-* and data-*</h3>
			<span x-child aria-label="Open menu" data-component="child-demo">
				<button type="button" class={buttonClasses} aria-label="Child label" data-track="child">
					Menu
				</button>
			</span>
			<p class="text-xs text-muted-foreground mt-2">
				Child <code>aria-label</code> and <code>data-track</code> win; missing <code>data-component</code> is copied.
			</p>
		</div>

		<div x-data="{ saved: false }">
			<h3 class="text-sm font-medium mb-2">Button with parent scope</h3>
			<span x-child @click="saved = !saved" class={buttonClasses}>
				<button type="button">
					<span x-text="saved ? 'Saved' : 'Save'"></span>
				</button>
			</span>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">x-child.replace</h3>
			<span x-child.replace class="wrapper-token" aria-label="Wrapper label">
				<button type="button" class={buttonClasses} aria-label="Child label">Replace mode</button>
			</span>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Known limitations</h3>
			<ul class="text-xs text-muted-foreground list-disc pl-5 space-y-1">
				<li>Only the first element child is kept — extra siblings are discarded with the wrapper.</li>
				<li>Runtime <code>addEventListener</code> on the wrapper is not transferred.</li>
				<li>Do not use on <code>x-for</code> / <code>x-if</code> wrappers.</li>
			</ul>
			<div class="mt-3 flex flex-wrap gap-2">
				<DemoButton
					@click="console.warn('[x-child demo] Wrapper without element child — check console.')"
					type="button"
				>
					Trigger no-child warning
				</DemoButton>
			</div>
		</div>
	</div>

	<p class="text-xs text-muted-foreground mt-6">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
