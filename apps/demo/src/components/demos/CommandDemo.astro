---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("command")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div
		class="grid gap-6"
		x-data
		x-init="
			$store.command.register({
				id: 'toggle-theme',
				label: 'Toggle theme',
				group: 'Appearance',
				shortcut: '⌘K',
				action: () => $store.theme.toggle(),
			});
			$store.command.register({
				id: 'toast-demo',
				label: 'Show toast',
				group: 'Actions',
				keywords: ['notify'],
				action: () => $toast.success('Command executed'),
			});
			$store.command.register({
				id: 'disabled-demo',
				label: 'Disabled action',
				group: 'Actions',
				disabled: true,
				action: () => {},
			});
		"
		@keydown.window="
			if (($event.metaKey || $event.ctrlKey) && $event.key.toLowerCase() === 'k') {
				$event.preventDefault();
				$store.command.toggle();
			}
			if ($store.command.isOpen) $store.command.handleKeydown($event);
		"
	>
		<div>
			<h3 class="text-sm font-medium mb-2">Command palette</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Open: <strong x-text="$store.command.isOpen"></strong> · Press
				<kbd class="px-1 rounded border">⌘K</kbd> or use the button
			</p>
			<DemoButton @click="$store.command.open()">Open command palette</DemoButton>
		</div>

		<template x-teleport="#overlay-root">
			<div
				x-show="$store.command.isOpen"
				x-transition
				class="fixed inset-0 flex items-start justify-center p-6 pt-[12vh]"
				:style="{ zIndex: $store.overlay.zIndexOf('command') ?? 1000 }"
			>
				<div class="absolute inset-0 bg-black/50" aria-hidden="true" @click="$store.command.close()"></div>
				<div
					class="relative z-10 w-full max-w-lg rounded-lg border bg-background shadow-2xl"
					role="dialog"
					aria-label="Command palette"
					x-effect="$store.command.isOpen && $nextTick(() => $el.querySelector('[data-command-search]')?.focus())"
				>
				<input
					type="search"
					data-command-search
					class="w-full border-b bg-transparent px-4 py-3 text-sm outline-none"
					placeholder="Search commands…"
					x-model="$store.command.search"
					aria-label="Search commands"
				/>
				<ul class="max-h-64 overflow-auto p-2">
					<template x-for="(item, index) in $store.command.filteredItems" :key="item.id">
						<li>
							<button
								type="button"
								class="flex w-full items-center justify-between rounded-md px-3 py-2 text-left text-sm"
								:class="index === $store.command.activeIndex ? 'bg-accent' : 'hover:bg-accent/60'"
								@click="$store.command.run(item.id)"
							>
								<span>
									<span x-text="item.label"></span>
									<span class="text-xs text-muted-foreground ml-2" x-text="item.group"></span>
								</span>
								<span class="text-xs text-muted-foreground" x-text="item.shortcut"></span>
							</button>
						</li>
					</template>
				</ul>
			</div>
		</div>
		</template>

		<div>
			<h3 class="text-sm font-medium mb-2">Integration</h3>
			<ul class="text-xs text-muted-foreground list-disc pl-5 space-y-1">
				<li>Actions can call <code>$toast</code>, <code>$store.theme</code>, or any app logic</li>
				<li>Pair with <code>@ailuracode/alpine-dialog</code> for modal command UIs</li>
				<li><code>filteredItems</code> and <code>groupedItems</code> update reactively from <code>search</code></li>
			</ul>
		</div>
	</div>

	<p class="text-xs text-muted-foreground mt-6">Package: <code>{plugin.package}</code></p>
</DemoSection>
