---
import { getPluginNavItem } from "../../plugin-nav";
import Badge from "../astro/Badge.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("screen")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p>
		Type: <strong x-text="$store.device.type"></strong> · Width:
		<strong x-text="$store.device.width"></strong>px · is(mobile):
		<strong x-text="$store.device.is('mobile')"></strong>
	</p>
	<div class="flex flex-wrap gap-2 mt-2">
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $store.device.type === 'mobile' }">Mobile</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $store.device.type === 'tablet' }">Tablet</Badge>
		<Badge x-bind:class="{ 'bg-primary text-primary-foreground': $store.device.type === 'desktop' }">Desktop</Badge>
	</div>
	<DemoButton class="mt-3" @click="$store.device.refresh()">refresh()</DemoButton>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
