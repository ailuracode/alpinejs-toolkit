---
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";
import Kbd from "../astro/Kbd.astro";

const plugin = getPluginNavItem("dialog")!;
const buttonClasses =
  "inline-flex items-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium hover:bg-accent";
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<!--
		The dialog registers `onClose` to defer the scroll unlock until the
		`x-transition` leave animation finishes. Without this delay,
		`$store.scroll.unlock()` runs synchronously inside `close()` and the
		scroll re-appears before the modal finish fading out — the body width
		shifts mid-animation, pushing the modal upward.

		The leave transition is 150ms here, so we wait one frame longer to
		cover the last paint. This is the simplest reliable fix without
		adding a `transitionend` listener or `scrollLock: false`.
	-->
	<div
		class="grid gap-6"
		x-data="{
			scrollHandle: null,
			registerDemo() {
				$store.dialog.register('settings', {
					labelledBy: 'dialog-title',
					describedBy: 'dialog-desc',
					scrollLock: false,
					onOpen: () => {
						if (!this.scrollHandle) {
							this.scrollHandle = $store.scroll.lock('dialog-demo');
						}
					},
					onClose: () => {
						const handle = this.scrollHandle;
						if (!handle) return;
						this.scrollHandle = null;
						// Defer unlock past the x-transition leave (150ms).
						setTimeout(() => $store.scroll.unlock(handle), 200);
					},
				});
			},
		}"
		x-init="registerDemo()"
		@keydown.window="$store.dialog.handleKeydown('settings', $event)"
	>
		<div>
			<h3 class="text-sm font-medium mb-2">Basic modal</h3>
			<p class="text-xs text-muted-foreground mb-3">
				Open state: <strong x-text="$store.dialog.isOpen('settings')"></strong>
			</p>
			<button type="button" class={buttonClasses} @click="$store.dialog.open('settings', { trigger: $event.target })">
				Open settings
			</button>

			<template x-teleport="#overlay-root">
				<div
					x-show="$store.dialog.isOpen('settings')"
					x-transition.duration.150ms
					class="fixed inset-0 flex items-center justify-center p-4"
					:style="{ zIndex: $store.overlay.zIndexOf('dialog', 'settings') }"
				>
					<div
						class="absolute inset-0 bg-black/50"
						aria-hidden="true"
						@click="$store.dialog.handleOutsideClick('settings', $event)"
					></div>
					<div
						class="relative z-10 w-full max-w-md rounded-lg border bg-background p-6 shadow-lg"
						x-bind="$store.dialog.dialogProps('settings')"
						x-init="$store.dialog.bindContainer('settings', $el)"
					>
						<h2 id="dialog-title" class="text-lg font-semibold">Settings</h2>
						<p id="dialog-desc" class="text-sm text-muted-foreground mt-1">
							Escape, overlay click, or the button below closes this dialog. Focus is trapped inside.
						</p>
						<div class="mt-4 flex gap-2">
							<button type="button" class={buttonClasses} @click="$store.dialog.close('settings')">Close</button>
							<button type="button" class={buttonClasses} @click="$toast.success('Saved from dialog')">Save + toast</button>
						</div>
					</div>
				</div>
			</template>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Keyboard &amp; accessibility</h3>
			<ul class="text-xs text-muted-foreground list-disc pl-5 space-y-1">
				<li><Kbd>Escape</Kbd> closes when <code>closeOnEscape</code> is enabled</li>
				<li>Scroll lock wired in the demo via <code>onOpen</code>/<code>onClose</code> + <code>$store.scroll</code></li>
				<li>The unlock is deferred 200ms to wait for the leave transition</li>
				<li><code>dialogProps()</code> sets <code>role="dialog"</code>, <code>aria-modal</code>, labelled/describedby</li>
			</ul>
		</div>

		<div>
			<h3 class="text-sm font-medium mb-2">Snippet</h3>
			<pre class="text-xs bg-muted p-3 rounded-md overflow-x-auto"><code>$store.dialog.open('settings')
$store.dialog.close('settings')
$store.dialog.dialogProps('settings')</code></pre>
		</div>
	</div>

	<p class="text-xs text-muted-foreground mt-6">Package: <code>{plugin.package}</code></p>
</DemoSection>
