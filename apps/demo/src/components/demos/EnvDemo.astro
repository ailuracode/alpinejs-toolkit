---
import { getPluginNavItem } from "../../plugin-nav";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("env")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div class="grid gap-4 sm:grid-cols-2 text-sm">
		<div class="rounded-lg border border-border p-3">
			<p class="font-medium mb-1">$network</p>
			<p
				x-bind:class="$network.isOnline ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400'"
				x-text="$network.isOnline ? 'Online' : 'Offline'"
			></p>
		</div>
		<div class="rounded-lg border border-border p-3">
			<p class="font-medium mb-1">$visibility</p>
			<p x-text="$visibility.isVisible ? 'Tab visible' : 'Tab hidden'"></p>
		</div>
		<div class="rounded-lg border border-border p-3">
			<p class="font-medium mb-1">$platform</p>
			<p>OS: <strong x-text="$platform.name"></strong></p>
		</div>
		<div class="rounded-lg border border-border p-3">
			<p class="font-medium mb-1">$battery</p>
			<p x-show="!$battery.isAvailable">API unavailable in this browser</p>
			<p x-show="$battery.isAvailable" x-cloak>
				Level: <strong x-text="Math.round(($battery.level ?? 0) * 100)"></strong>%
			</p>
		</div>
	</div>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code> — one install for all environment magics.
	</p>
</DemoSection>
