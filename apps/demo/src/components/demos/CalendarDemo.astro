---
import { calendarDayButtonClass, segmentButtonActiveClass } from "../../lib/button-styles";
import { getPluginNavItem } from "../../plugin-nav";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("calendar")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<div x-data="calendarDemo" class="grid gap-4">
		<div class="flex flex-wrap gap-2">
			<span class="text-xs font-semibold text-[var(--ios-label-secondary)] self-center mr-1">Mode</span>
			<DemoButton class={segmentButtonActiveClass} x-bind:data-active="mode === 'single' ? 'true' : null" @click="setMode('single')">Single</DemoButton>
			<DemoButton class={segmentButtonActiveClass} x-bind:data-active="mode === 'range' ? 'true' : null" @click="setMode('range')">Range</DemoButton>
			<DemoButton class={segmentButtonActiveClass} x-bind:data-active="mode === 'multiple' ? 'true' : null" @click="setMode('multiple')">Multiple</DemoButton>
		</div>

		<div class="flex flex-wrap gap-2">
			<span class="text-xs font-semibold text-[var(--ios-label-secondary)] self-center mr-1">Locale</span>
			<DemoButton class={segmentButtonActiveClass} x-bind:data-active="localeCode === 'en' ? 'true' : null" @click="setLocale('en')">enUS</DemoButton>
			<DemoButton class={segmentButtonActiveClass} x-bind:data-active="localeCode === 'es' ? 'true' : null" @click="setLocale('es')">es</DemoButton>
		</div>

		<div class="flex flex-wrap items-center gap-2">
			<DemoButton @click="cal.prevMonth()">Previous</DemoButton>
			<strong x-text="cal.formatMonth()"></strong>
			<DemoButton @click="cal.nextMonth()">Next</DemoButton>
			<DemoButton @click="cal.goToToday()">Today</DemoButton>
			<DemoButton @click="jumpNextMonth()">Jump +2 Months</DemoButton>
			<DemoButton @click="clear()">Clear</DemoButton>
		</div>

		<div class="grid grid-cols-7 gap-1">
			<template x-for="label in cal.weekdayLabels" :key="label">
				<span class="text-center text-xs font-semibold text-[var(--ios-label-secondary)] py-1" x-text="label"></span>
			</template>
		</div>

		<template x-for="week in cal.weeks" :key="week[0].date.toISOString()">
			<div class="grid grid-cols-7 gap-1">
				<template x-for="day in week" :key="day.date.toISOString()">
					<DemoButton
						type="button"
						variant="ghost"
						size="icon"
						class={calendarDayButtonClass}
						x-bind:disabled="day.isDisabled"
						x-bind:class="{
							'opacity-45': !day.isCurrentMonth,
							'border border-[var(--ios-blue)] text-primary': day.isToday && !day.isSelected && !day.isInRange,
							'bg-[var(--ios-blue)] text-white hover:bg-[var(--ios-blue)]/80': day.isSelected && cal.mode === 'single',
							'bg-[var(--ios-blue)]/15': day.isInRange && cal.mode === 'range',
							'bg-[var(--ios-blue)] text-white hover:bg-[var(--ios-blue)]/80': day.isRangeStart || day.isRangeEnd,
							'ring-2 ring-primary/40': cal.mode === 'multiple' && day.isSelected,
						}"
						@click="cal.select(day.date)"
						x-text="cal.format(day.date, 'd')"
					/>
				</template>
			</div>
		</template>

		<p class="text-sm text-green-600 dark:text-green-400">
			Selection (<span x-text="mode"></span>):
			<strong x-text="selectionLabel()"></strong>
		</p>
		<p class="text-sm text-[var(--ios-label-secondary)]">
			Weekends disabled · <code>minDate</code> / <code>maxDate</code> bound to current quarter.
		</p>
	</div>
	<p class="text-xs text-[var(--ios-label-secondary)] mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>

<DemoSection
	title="Range · 2 months"
	description="Side-by-side grids with numberOfMonths: 2. Global prev/next moves the anchor by two months."
>
	<div x-data="calendarRangeDemo" class="grid gap-4">
		<div class="flex flex-wrap items-center gap-2">
			<DemoButton @click="cal.prevMonth()">Previous</DemoButton>
			<DemoButton @click="cal.nextMonth()">Next</DemoButton>
			<DemoButton @click="cal.goToToday()">Today</DemoButton>
			<DemoButton @click="clear()">Clear</DemoButton>
		</div>

		<div class="relative flex flex-col gap-4 md:flex-row md:items-start">
			<template x-for="monthView in cal.months" :key="monthView.month.toISOString()">
				<div class="flex w-full min-w-0 flex-col gap-2 rounded-[var(--ios-radius-md)] border border-[var(--ios-separator)] p-3">
					<strong class="text-sm" x-text="cal.formatMonth(monthView.month)"></strong>

					<div class="grid grid-cols-7 gap-1">
						<template x-for="label in cal.weekdayLabels" :key="`${monthView.month.toISOString()}-${label}`">
							<span class="text-center text-xs font-semibold text-[var(--ios-label-secondary)] py-1" x-text="label"></span>
						</template>
					</div>

					<template x-for="week in monthView.weeks" :key="week[0].date.toISOString()">
						<div class="grid grid-cols-7 gap-1">
							<template x-for="day in week" :key="day.date.toISOString()">
								<DemoButton
									type="button"
									variant="ghost"
									size="icon"
									class={calendarDayButtonClass}
									x-bind:disabled="day.isDisabled"
									x-bind:class="{
										'opacity-45': !day.isCurrentMonth,
										'border border-[var(--ios-blue)] text-primary': day.isToday && !day.isRangeStart && !day.isRangeEnd && !day.isInRange,
										'bg-[var(--ios-blue)]/15': day.isInRange,
										'bg-[var(--ios-blue)] text-white hover:bg-[var(--ios-blue)]/80': day.isRangeStart || day.isRangeEnd,
									}"
									@click="cal.select(day.date)"
									x-text="cal.format(day.date, 'd')"
								/>
							</template>
						</div>
					</template>
				</div>
			</template>
		</div>

		<p class="text-sm text-green-600 dark:text-green-400">
			Selection:
			<strong x-text="selectionLabel()"></strong>
		</p>
		<p class="text-sm text-[var(--ios-label-secondary)]">
			Loop <code>cal.months</code> for each grid · shared <code>cal.select()</code> across both months.
		</p>
	</div>
</DemoSection>
