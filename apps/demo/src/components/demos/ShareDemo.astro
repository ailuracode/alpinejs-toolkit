---
import { getPluginNavItem } from "../../plugin-nav";
import Alert from "../astro/Alert.astro";
import DemoButton from "../astro/DemoButton.astro";
import DemoSection from "../DemoSection.astro";

const plugin = getPluginNavItem("share")!;
---

<DemoSection id={plugin.id} title={plugin.title} api={plugin.api} description={plugin.description}>
	<p class="text-sm text-muted-foreground" x-show="!$share.isSupported" x-cloak>
		Web Share API is not available in this browser.
	</p>
	<template x-if="$share.isSupported">
		<div>
			<div class="flex flex-wrap gap-2">
				<DemoButton @click="shared = await $share({ title: document.title, text: 'Check out this Alpine.js plugin demo', url: window.location.href })">
					Share page
				</DemoButton>
				<DemoButton
					x-bind:disabled="!$share.canShare({ title: document.title, url: window.location.href })"
					@click="shared = await $share({ title: document.title, url: window.location.href })"
				>
					canShare guard
				</DemoButton>
			</div>
			<Alert variant="success" class="mt-3" x-show="shared === true" x-cloak>
				<span>Thanks for sharing!</span>
			</Alert>
			<Alert variant="info" class="mt-3" x-show="shared === false" x-cloak>
				<span>Share cancelled.</span>
			</Alert>
		</div>
	</template>
	<p class="text-xs text-muted-foreground mt-3">
		Package: <code>{plugin.package}</code>
	</p>
</DemoSection>
