---
import { PLUGIN_NAV_GROUPS, playgroundPath } from "../plugin-nav";
import DemoNavIcon from "./astro/DemoNavIcon.astro";
import Separator from "./astro/Separator.astro";

interface Props {
  activePlugin?: string;
}

const { activePlugin = "overview" } = Astro.props;

const navLinkClass = (id: string) => {
  const active = activePlugin === id;

  return [
    "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-sidebar-ring/50",
    active
      ? "bg-sidebar-accent font-medium text-sidebar-accent-foreground"
      : "text-sidebar-foreground/80 hover:bg-sidebar-accent/60 hover:text-sidebar-accent-foreground",
  ].join(" ");
};
---

<!-- Sidebar overlay — mobile only (native button — not DemoButton; must cover full viewport) -->
<button
	type="button"
	x-show="$store.device.type !== 'desktop' && $store.sidebar.open"
	x-transition.opacity
	class="fixed inset-0 z-30 border-0 bg-black/50 p-0 motion-reduce:transition-none"
	x-on:click="$store.sidebar.hide()"
	aria-label="Close navigation"
	style="display: none;"
></button>

<!-- Left sidebar — persistent on desktop, drawer on mobile -->
<aside
	x-show="$store.device.type === 'desktop' || $store.sidebar.open"
	x-transition:enter="transition ease-out duration-300 motion-reduce:transition-none"
	x-transition:enter-start="-translate-x-full"
	x-transition:enter-end="translate-x-0"
	x-transition:leave="transition ease-in duration-200 motion-reduce:transition-none"
	x-transition:leave-start="translate-x-0"
	x-transition:leave-end="-translate-x-full"
	class="fixed inset-y-0 left-0 z-40 flex flex-col overflow-hidden border-r border-sidebar-border bg-sidebar text-sidebar-foreground shadow-xl transition-[width] duration-300 ease-out motion-reduce:transition-none"
	x-cloak
	x-bind:class="$store.device.type === 'desktop' && $store.sidebar.collapsed ? 'w-16' : 'w-64'"
	aria-label="Playground navigation"
>
	<!-- Logo -->
	<a
		href="/playground/"
		class="flex h-14 shrink-0 items-center border-b border-sidebar-border transition-colors hover:bg-sidebar-accent/40"
		x-bind:class="$store.sidebar.collapsed ? 'justify-center px-2' : 'px-4'"
		x-on:click="$store.device.type !== 'desktop' && $store.sidebar.hide()"
	>
		<div class="flex items-center gap-3 overflow-hidden">
			<img src="/logo.png" alt="" width="32" height="32" class="size-8 shrink-0 rounded-lg" />
			<span
				class="overflow-hidden whitespace-nowrap text-sm font-bold transition-[max-width,opacity] duration-300 motion-reduce:transition-none"
				x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
			>
				Alpine Plugins
			</span>
		</div>
	</a>

	<!-- Navigation -->
	<nav class="flex min-h-0 flex-1 flex-col gap-0.5 overflow-y-auto overscroll-contain p-2" aria-label="Plugins">
		<a
			href="/playground/"
			class={navLinkClass("overview")}
			title="Overview"
			aria-current={activePlugin === "overview" ? "page" : undefined}
			x-on:click="$store.device.type !== 'desktop' && $store.sidebar.hide()"
		>
			<DemoNavIcon id="overview" />
			<span
				class="overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-300 motion-reduce:transition-none"
				x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
			>
				Overview
			</span>
		</a>

		<Separator class="my-2 bg-sidebar-border" />

		{
			PLUGIN_NAV_GROUPS.map((group) => (
				<>
					<div
						class="overflow-hidden px-3 pt-2 pb-1 text-[10px] font-semibold tracking-wider whitespace-nowrap text-sidebar-foreground/50 uppercase transition-[max-width,opacity] duration-300 motion-reduce:transition-none"
						x-bind:class="$store.sidebar.collapsed ? 'max-h-0 max-w-0 py-0 opacity-0' : 'max-h-8 max-w-[180px] opacity-100'"
					>
						{group.label}
					</div>
					{group.items.map((item) => (
						<a
							href={playgroundPath(item.id)}
							class={navLinkClass(item.id)}
							title={item.title}
							aria-current={activePlugin === item.id ? "page" : undefined}
							x-on:click="$store.device.type !== 'desktop' && $store.sidebar.hide()"
						>
							<DemoNavIcon id={item.id} />
							<span
								class="overflow-hidden whitespace-nowrap transition-[max-width,opacity] duration-300 motion-reduce:transition-none"
								x-bind:class="$store.sidebar.collapsed ? 'max-w-0 opacity-0' : 'max-w-[180px] opacity-100'"
							>
								{item.title}
							</span>
						</a>
					))}
				</>
			))
		}
	</nav>

	<div
		class="shrink-0 border-t border-sidebar-border p-3 text-[10px] leading-snug text-sidebar-foreground/60"
		x-show="!$store.sidebar.collapsed"
		x-cloak
	>
		<p class="px-1">{PLUGIN_NAV_GROUPS.reduce((n, g) => n + g.items.length, 0)} plugins · one demo per page</p>
	</div>
</aside>
