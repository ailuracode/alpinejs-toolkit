---
import { PLUGIN_NAV_GROUPS, playgroundPath } from "../plugin-nav";
import Button from "./astro/Button.astro";
import DemoNavIcon from "./astro/DemoNavIcon.astro";
import Separator from "./astro/Separator.astro";

interface Props {
  activePlugin?: string;
}

const { activePlugin = "overview" } = Astro.props;

const navLinkClass = (id: string) => {
  const active = activePlugin === id;

  return [
    "relative flex h-10 w-full items-center rounded-lg text-sm transition-[background-color,color,gap,padding] duration-200 motion-reduce:transition-none",
    "focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-sidebar-ring/50 touch-manipulation",
    active
      ? "bg-sidebar-accent font-medium text-sidebar-accent-foreground before:absolute before:inset-y-2 before:left-0 before:w-0.5 before:rounded-full before:bg-sidebar-primary"
      : "text-sidebar-foreground/80 hover:bg-sidebar-accent/60 hover:text-sidebar-accent-foreground",
  ].join(" ");
};
---

<!-- Sidebar overlay — mobile only -->
<button
	type="button"
	x-show="$store.media.breakpoint !== 'desktop' && $store.sidebar.visible"
	x-transition.opacity
	class="fixed inset-0 z-30 border-0 bg-black/50 p-0 motion-reduce:transition-none touch-manipulation"
	x-on:click="$store.sidebar.hide()"
	aria-label="Close navigation"
	style="display: none;"
></button>

<aside
	x-show="$store.media.breakpoint === 'desktop' || $store.sidebar.visible"
	x-transition:enter="transition ease-out duration-300 motion-reduce:transition-none"
	x-transition:enter-start="-translate-x-full"
	x-transition:enter-end="translate-x-0"
	x-transition:leave="transition ease-in duration-200 motion-reduce:transition-none"
	x-transition:leave-start="translate-x-0"
	x-transition:leave-end="-translate-x-full"
	class="fixed inset-y-0 left-0 z-40 flex flex-col overflow-hidden border-r border-sidebar-border bg-sidebar text-sidebar-foreground shadow-xl transition-[width] duration-300 ease-out motion-reduce:transition-none"
	x-cloak
	x-bind:class="$store.media.breakpoint === 'desktop' && !expanded ? 'w-16' : 'w-64'"
	aria-label="Playground navigation"
>
	<a
		href="/playground/"
		class="flex h-14 shrink-0 items-center border-b border-sidebar-border transition-[padding] duration-200 hover:bg-sidebar-accent/40 focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-sidebar-ring/50 focus-visible:ring-inset motion-reduce:transition-none"
		x-bind:class="expanded ? 'justify-start gap-3 px-4' : 'justify-center px-0'"
		x-on:click="$store.media.breakpoint !== 'desktop' && $store.sidebar.hide()"
		aria-current={activePlugin === "overview" ? "page" : undefined}
	>
		<img src="/logo.png" alt="" width="32" height="32" class="size-8 shrink-0 rounded-lg" />
		<span
			class="overflow-hidden whitespace-nowrap text-sm font-bold"
			x-show="expanded"
			x-cloak
		>
			Alpine Plugins
		</span>
	</a>

	<nav
		class="flex min-h-0 flex-1 flex-col gap-0.5 overflow-y-auto overscroll-contain transition-[padding] duration-200 motion-reduce:transition-none"
		x-bind:class="expanded ? 'p-2' : 'px-1.5 py-2'"
		aria-label="Plugins"
	>
		<a
			href="/playground/"
			class={navLinkClass("overview")}
			aria-current={activePlugin === "overview" ? "page" : undefined}
			x-bind:aria-label="!expanded ? 'Overview' : null"
			x-bind:class="expanded ? 'gap-3 px-3' : 'justify-center gap-0 px-0'"
			x-on:click="$store.media.breakpoint !== 'desktop' && $store.sidebar.hide()"
		>
			<DemoNavIcon id="overview" class="size-5" />
			<span class="truncate whitespace-nowrap" x-show="expanded" x-cloak>Overview</span>
		</a>

		<Separator
			class="bg-sidebar-border transition-[margin,width] duration-200 motion-reduce:transition-none"
			x-bind:class="expanded ? 'my-2' : 'mx-auto my-2 w-8'"
		/>

		{
			PLUGIN_NAV_GROUPS.map((group) => (
				<>
					<div
						class="px-3 pt-2 pb-1 text-[10px] font-semibold tracking-wider whitespace-nowrap text-sidebar-foreground/50 uppercase"
						x-show="expanded"
						x-cloak
						aria-hidden="true"
					>
						{group.label}
					</div>
					{group.items.map((item) => (
						<a
							href={playgroundPath(item.id)}
							class={navLinkClass(item.id)}
							aria-current={activePlugin === item.id ? "page" : undefined}
							x-bind:aria-label={`!expanded ? ${JSON.stringify(item.title)} : null`}
							x-bind:class="expanded ? 'gap-3 px-3' : 'justify-center gap-0 px-0'"
							x-on:click="$store.media.breakpoint !== 'desktop' && $store.sidebar.hide()"
						>
							<DemoNavIcon id={item.id} class="size-5" />
							<span class="truncate whitespace-nowrap" x-show="expanded" x-cloak>
								{item.title}
							</span>
						</a>
					))}
				</>
			))
		}
	</nav>

	<div
		class="flex shrink-0 flex-col border-t border-sidebar-border transition-[padding] duration-200 motion-reduce:transition-none"
		x-bind:class="expanded ? 'p-2' : 'px-1.5 py-2'"
	>
		<Button
			variant="ghost"
			size="sm"
			class="hidden text-sidebar-foreground/80 hover:bg-sidebar-accent/60 hover:text-sidebar-accent-foreground sm:inline-flex motion-reduce:transition-none"
			x-show="$store.media.breakpoint === 'desktop'"
			x-on:click="expanded = !expanded"
			x-bind:aria-label="expanded ? 'Collapse sidebar' : 'Expand sidebar'"
			x-bind:aria-expanded="expanded"
			x-bind:class="expanded ? 'h-7 w-full justify-start' : 'mx-auto size-9 justify-center px-0'"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				class="size-4 shrink-0"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
				stroke-width="2"
				aria-hidden="true"
				x-show="!expanded"
				x-cloak
			>
				<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
			</svg>
			<span x-show="expanded" x-cloak>Collapse</span>
		</Button>
		<p
			class="px-1 pt-2 text-center text-[10px] leading-snug text-sidebar-foreground/60"
			x-show="expanded"
			x-cloak
		>
			{PLUGIN_NAV_GROUPS.reduce((n, g) => n + g.items.length, 0)} modules · one demo per page
		</p>
	</div>
</aside>
