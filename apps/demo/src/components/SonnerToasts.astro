---
/** Sonner-style toast renderer for @ailuracode/alpinejs-toast — shadcn appearance via sonner.css */
---

<div
	class="z-[100] pointer-events-none fixed inset-0"
	data-slot="sonner"
	x-data="toastSonner({ richColors: true })"
>
	<template x-for="position in activePositions()" :key="position">
		<div
			class="toaster-group"
			data-sonner-toaster-group
			x-bind:data-x-position="xPosition(position)"
			x-bind:data-y-position="yPosition(position)"
		>
			<ol
				class="toaster group"
				data-sonner-toaster
				data-stack="persistent"
				x-show="hasPersistentToasts(position)"
				x-bind:data-x-position="xPosition(position)"
				x-bind:data-y-position="yPosition(position)"
				x-bind:style="persistentToasterStyle(position)"
			>
				<template x-for="toast in persistentToastsAt(position)" :key="toast.id">
					<li
						data-sonner-toast
						data-styled="true"
						role="status"
						x-bind:data-dismissible="'true'"
						x-bind:data-expanded="'true'"
						x-bind:data-front="'true'"
						x-bind:data-mounted="isMounted(toast) ? 'true' : 'false'"
						x-bind:data-removed="isToastRemoved(toast.id) ? 'true' : 'false'"
						x-bind:data-rich-colors="richColors ? 'true' : 'false'"
						x-bind:data-swipe-direction="getSwipeDirection(toast)"
						x-bind:data-swipe-out="getSwipeOut(toast) ? 'true' : 'false'"
						x-bind:data-swiping="swipingId === toast.id ? 'true' : 'false'"
						x-bind:data-type="toastType(toast)"
						x-bind:data-visible="'true'"
						x-bind:data-x-position="xPosition(position)"
						x-bind:data-y-position="yPosition(position)"
						x-bind:style="persistentToastStyle(toast)"
						x-init="initToast($el, toast, 0, position)"
						x-on:pointercancel="endSwipe($event, toast, position)"
						x-on:pointerdown="startSwipe($event, toast)"
						x-on:pointermove="moveSwipe($event, toast, position)"
						x-on:pointerup="endSwipe($event, toast, position)"
					>
						<button
							aria-label="Dismiss toast"
							data-close-button
							type="button"
							x-on:click.stop="dismiss(toast.id)"
						>
							<svg aria-hidden="true" class="size-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M18 6 6 18M6 6l12 12" />
							</svg>
						</button>

						<div data-icon x-show="showIcon(toast)">
							<span class="contents" x-cloak x-show="toast.variant === 'success'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10" />
									<path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'info'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-4M12 8h.01" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'warning'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4M12 17h.01" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'error'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 6h.01M4.93 4.93l14.14 14.14" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M7.86 2.18A10 10 0 1 0 21.82 16.14" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'loading'">
								<svg aria-hidden="true" class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-6.219-8.56" />
								</svg>
							</span>
						</div>

						<div data-content>
							<span
								class="inline-flex h-5 w-fit shrink-0 items-center rounded-full border border-border px-2 text-xs font-medium mb-1"
								x-show="toast.content?.kind === 'badge'"
								x-text="toast.content?.label"
							></span>
							<div data-title x-show="toast.title" x-text="toast.title"></div>
							<div data-description x-show="toast.description" x-text="toast.description"></div>
						</div>

						<button
							data-button
							type="button"
							x-on:click.stop="runAction(toast)"
							x-show="showAction(toast)"
							x-text="toast.action?.label"
						></button>
					</li>
				</template>
			</ol>

			<ol
				class="toaster group"
				data-sonner-toaster
				data-stack="timed"
				x-show="hasTimedToasts(position)"
				x-bind:data-x-position="xPosition(position)"
				x-bind:data-y-position="yPosition(position)"
				x-bind:style="timedToasterStyle(position)"
				x-on:mouseenter="setExpanded(position, true)"
				x-on:mouseleave="setExpanded(position, false)"
			>
				<template x-for="(toast, index) in timedToastsAt(position)" :key="toast.id">
					<li
						data-sonner-toast
						data-styled="true"
						role="status"
						x-bind:data-dismissible="'true'"
						x-bind:data-expanded="isExpanded(position) ? 'true' : 'false'"
						x-bind:data-front="isFront(index) ? 'true' : 'false'"
						x-bind:data-mounted="isMounted(toast) ? 'true' : 'false'"
						x-bind:data-removed="isToastRemoved(toast.id) ? 'true' : 'false'"
						x-bind:data-rich-colors="richColors ? 'true' : 'false'"
						x-bind:data-swipe-direction="getSwipeDirection(toast)"
						x-bind:data-swipe-out="getSwipeOut(toast) ? 'true' : 'false'"
						x-bind:data-swiping="swipingId === toast.id ? 'true' : 'false'"
						x-bind:data-type="toastType(toast)"
						x-bind:data-visible="isVisible(position, index) ? 'true' : 'false'"
						x-bind:data-x-position="xPosition(position)"
						x-bind:data-y-position="yPosition(position)"
						x-bind:style="timedToastStyle(toast, index, position)"
						x-init="initToast($el, toast, index, position)"
						x-on:pointercancel="endSwipe($event, toast, position)"
						x-on:pointerdown="startSwipe($event, toast)"
						x-on:pointermove="moveSwipe($event, toast, position)"
						x-on:pointerup="endSwipe($event, toast, position)"
					>
						<button
							aria-label="Dismiss toast"
							data-close-button
							type="button"
							x-on:click.stop="dismiss(toast.id)"
						>
							<svg aria-hidden="true" class="size-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M18 6 6 18M6 6l12 12" />
							</svg>
						</button>

						<div data-icon x-show="showIcon(toast)">
							<span class="contents" x-cloak x-show="toast.variant === 'success'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10" />
									<path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'info'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<circle cx="12" cy="12" r="10" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-4M12 8h.01" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'warning'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4M12 17h.01" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'error'">
								<svg aria-hidden="true" class="size-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 6h.01M4.93 4.93l14.14 14.14" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M7.86 2.18A10 10 0 1 0 21.82 16.14" />
								</svg>
							</span>
							<span class="contents" x-cloak x-show="toast.variant === 'loading'">
								<svg aria-hidden="true" class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-6.219-8.56" />
								</svg>
							</span>
						</div>

						<div data-content>
							<span
								class="inline-flex h-5 w-fit shrink-0 items-center rounded-full border border-border px-2 text-xs font-medium mb-1"
								x-show="toast.content?.kind === 'badge'"
								x-text="toast.content?.label"
							></span>
							<div data-title x-show="toast.title" x-text="toast.title"></div>
							<div data-description x-show="toast.description" x-text="toast.description"></div>
						</div>

						<button
							data-button
							type="button"
							x-on:click.stop="runAction(toast)"
							x-show="showAction(toast)"
							x-text="toast.action?.label"
						></button>
					</li>
				</template>
			</ol>
		</div>
	</template>
</div>
