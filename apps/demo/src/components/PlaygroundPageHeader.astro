---
import { Card, CardContent } from "@/components/ui/card";
import { type PluginNavItem, pluginDocsPath } from "../plugin-nav";
import Badge from "./astro/Badge.astro";
import DemoButton from "./astro/DemoButton.astro";

interface Props {
  item: PluginNavItem;
}

const { item } = Astro.props;

const kindLabel = item.kind === "store" ? "Store" : item.kind === "magic" ? "Magic" : "Core";
---

<header class="mb-6 scroll-mt-20">
	<nav class="mb-3 text-sm text-muted-foreground" aria-label="Breadcrumb">
		<ol class="flex flex-wrap items-center gap-1.5">
			<li>
				<a href="/playground/" class="hover:text-foreground transition-colors">Playground</a>
			</li>
			<li aria-hidden="true" class="text-border">/</li>
			<li aria-current="page" class="text-foreground font-medium">{item.title}</li>
		</ol>
	</nav>

	<Card size="sm">
		<CardContent class="pt-4">
			<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div class="min-w-0 space-y-2">
					<h1 class="text-2xl font-semibold tracking-tight text-balance">{item.title}</h1>
					<p class="text-sm text-muted-foreground text-pretty">{item.description}</p>
				</div>
				<div class="flex flex-wrap gap-2 shrink-0">
					<Badge variant="secondary">{kindLabel}</Badge>
					<Badge variant="outline" class="font-mono text-[11px]">{item.api}</Badge>
				</div>
			</div>
			<div class="mt-4 flex flex-wrap items-center gap-3">
				<DemoButton href={pluginDocsPath(item.id)} variant="default">
					Read Documentation
				</DemoButton>
				<span class="text-xs text-muted-foreground font-mono">{item.package}</span>
			</div>
		</CardContent>
	</Card>
</header>
