---
import { getPluginsByTier, PLUGIN_NAV_GROUPS, PLUGIN_NAV_ITEMS } from "../plugin-nav";
import PlaygroundModuleCard from "./PlaygroundModuleCard.astro";

const essentialItems = getPluginsByTier("essential");
const extendedGroups = PLUGIN_NAV_GROUPS.filter((group) => group.id !== "essentials");
const moduleCount = PLUGIN_NAV_ITEMS.length;
---

<header class="mb-8 scroll-mt-20 gradient-mesh rounded-[var(--ios-radius-xl)] p-6 -mx-6 fade-in-up">
	<p class="text-sm font-semibold tracking-wide text-[var(--ios-blue)]">Interactive demos</p>
	<h1 class="mt-1 text-4xl font-bold tracking-tight text-balance">Playground</h1>
	<p class="mt-2 max-w-2xl text-sm leading-relaxed text-[var(--ios-label-secondary)] text-pretty">
		Explore <strong class="font-medium text-[var(--ios-label)]">{moduleCount} Alpine.js plugins</strong> with live
		examples. Each page loads one module — start with essentials, then try environment, data, and query
		stacks.
	</p>
	<dl class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
		<div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20 fade-in-up fade-in-up-delay-1">
			<dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Modules</dt>
			<dd class="mt-1 text-xl font-bold tabular-nums">{moduleCount}</dd>
		</div>
		<div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20 fade-in-up fade-in-up-delay-2">
			<dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Essentials</dt>
			<dd class="mt-1 text-xl font-bold tabular-nums">{essentialItems.length}</dd>
		</div>
		<div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20 fade-in-up fade-in-up-delay-3">
			<dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Groups</dt>
			<dd class="mt-1 text-xl font-bold tabular-nums">{PLUGIN_NAV_GROUPS.length}</dd>
		</div>
		<div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20 fade-in-up fade-in-up-delay-4">
			<dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Stack</dt>
			<dd class="mt-1 text-sm font-bold leading-tight">Alpine · Astro</dd>
		</div>
	</dl>
</header>

<section aria-labelledby="essentials-heading" class="mb-10">
	<div class="mb-4 flex items-end justify-between gap-3">
		<div>
			<h2 id="essentials-heading" class="text-xl font-bold tracking-tight text-balance">Essentials</h2>
			<p class="text-sm text-[var(--ios-label-secondary)]">Recommended starting point for most apps</p>
		</div>
	</div>
	<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
		{essentialItems.map((item) => <PlaygroundModuleCard item={item} />)}
	</div>
</section>

{
	extendedGroups.map((group) => (
		<section aria-labelledby={`group-${group.id}`} class="mb-10 last:mb-0">
			<div class="mb-4">
				<h2 id={`group-${group.id}`} class="text-xl font-bold tracking-tight text-balance">
					{group.label}
				</h2>
				<p class="text-sm text-[var(--ios-label-secondary)]">
					{group.items.length} {group.items.length === 1 ? "module" : "modules"}
				</p>
			</div>
			<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
				{group.items.map((item) => (
					<PlaygroundModuleCard item={item} />
				))}
			</div>
		</section>
	))
}

<footer class="mt-10 border-t border-[var(--ios-separator)] pt-6 text-xs text-[var(--ios-label-secondary)]">
	<p>
		<a href="/getting-started/" class="font-semibold text-[var(--ios-blue)] underline-offset-4 hover:underline">
			Getting started
		</a>
		<span aria-hidden="true"> · </span>
		<a href="/core/" class="font-semibold text-[var(--ios-blue)] underline-offset-4 hover:underline">Core registry</a>
		<span aria-hidden="true"> · </span>
		<a
			href="https://github.com/ailuracode/alpinejs-toolkit"
			target="_blank"
			rel="noreferrer"
			class="font-semibold text-[var(--ios-blue)] underline-offset-4 hover:underline"
		>
			GitHub
			<span class="sr-only"> (opens in new tab)</span>
		</a>
	</p>
</footer>
