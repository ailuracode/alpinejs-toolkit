---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { PLUGIN_NAV_GROUPS, playgroundPath } from "../plugin-nav";
import Badge from "./astro/Badge.astro";
import DemoSection from "./DemoSection.astro";

const totalPlugins = PLUGIN_NAV_GROUPS.reduce((count, group) => count + group.items.length, 0);
---

<DemoSection id="overview" title="Plugin Catalog" api="@ailuracode/alpine-*">
	<p class="text-sm text-muted-foreground text-pretty">
		Interactive reference for <strong>{totalPlugins}</strong> Alpine.js plugins published under
		<code class="rounded bg-muted px-1 py-0.5 font-mono text-xs text-foreground">@ailuracode</code>.
		Pick a plugin in the sidebar or browse by category below — each page shows the npm package, store or magic API,
		and a live demo.
	</p>

	<div class="grid gap-4 sm:grid-cols-2">
		{
			PLUGIN_NAV_GROUPS.map((group) => (
				<Card size="sm">
					<CardHeader>
						<CardTitle>{group.label}</CardTitle>
						<CardDescription>
							{group.items.length} {group.items.length === 1 ? "plugin" : "plugins"}
						</CardDescription>
					</CardHeader>
					<CardContent>
						<ul class="space-y-1">
							{group.items.map((item) => (
								<li>
									<a
										href={playgroundPath(item.id)}
										class="group flex min-w-0 items-center justify-between gap-2 rounded-lg px-2 py-2 -mx-2 transition-colors hover:bg-muted focus-visible:outline-none focus-visible:ring-3 focus-visible:ring-ring/50"
									>
										<span class="truncate font-medium group-hover:text-primary">{item.title}</span>
										<Badge variant="outline" class="shrink-0 font-mono text-[10px]">
											{item.api}
										</Badge>
									</a>
								</li>
							))}
						</ul>
					</CardContent>
				</Card>
			))
		}
	</div>

	<div class="flex flex-wrap gap-2">
		<Badge variant="secondary">Stores</Badge>
		<Badge variant="secondary">Magics</Badge>
		<Badge variant="secondary">Query Core</Badge>
		<Badge variant="outline">Astro + shadcn/ui</Badge>
	</div>

	<p class="text-xs text-muted-foreground">
		<a href="/" class="font-medium text-primary underline-offset-4 hover:underline">Full documentation</a>
		<span aria-hidden="true"> · </span>
		<a
			href="https://github.com/ailuracode/alpine"
			target="_blank"
			rel="noreferrer"
			class="text-primary underline-offset-4 hover:underline"
		>
			GitHub
		</a>
		<span aria-hidden="true"> · </span>
		<a
			href="https://www.npmjs.com/~siddharthagf"
			target="_blank"
			rel="noreferrer"
			class="text-primary underline-offset-4 hover:underline"
		>
			npm
		</a>
	</p>
</DemoSection>
