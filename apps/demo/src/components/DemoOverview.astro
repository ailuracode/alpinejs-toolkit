---
import { getPluginsByTier, PLUGIN_NAV_GROUPS, PLUGIN_NAV_ITEMS } from "../plugin-nav";
import PlaygroundModuleCard from "./PlaygroundModuleCard.astro";

const essentialItems = getPluginsByTier("essential");
const extendedGroups = PLUGIN_NAV_GROUPS.filter((group) => group.id !== "essentials");
const moduleCount = PLUGIN_NAV_ITEMS.length;
---

<header class="mb-8 scroll-mt-20">
	<p class="text-sm font-medium text-primary">Interactive demos</p>
	<h1 class="mt-1 text-3xl font-semibold tracking-tight text-balance">Playground</h1>
	<p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted-foreground text-pretty">
		Explore <strong class="font-medium text-foreground">{moduleCount} Alpine.js plugins</strong> with live
		examples. Each page loads one module — start with essentials, then try environment, data, and query
		stacks.
	</p>
	<dl class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-4">
		<div class="rounded-lg border border-border bg-muted/40 px-3 py-2">
			<dt class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">Modules</dt>
			<dd class="mt-0.5 text-lg font-semibold tabular-nums">{moduleCount}</dd>
		</div>
		<div class="rounded-lg border border-border bg-muted/40 px-3 py-2">
			<dt class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">Essentials</dt>
			<dd class="mt-0.5 text-lg font-semibold tabular-nums">{essentialItems.length}</dd>
		</div>
		<div class="rounded-lg border border-border bg-muted/40 px-3 py-2">
			<dt class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">Groups</dt>
			<dd class="mt-0.5 text-lg font-semibold tabular-nums">{PLUGIN_NAV_GROUPS.length}</dd>
		</div>
		<div class="rounded-lg border border-border bg-muted/40 px-3 py-2">
			<dt class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">Stack</dt>
			<dd class="mt-0.5 text-sm font-semibold leading-tight">Alpine · Astro</dd>
		</div>
	</dl>
</header>

<section aria-labelledby="essentials-heading" class="mb-10">
	<div class="mb-4 flex items-end justify-between gap-3">
		<div>
			<h2 id="essentials-heading" class="text-lg font-semibold text-balance">Essentials</h2>
			<p class="text-sm text-muted-foreground">Recommended starting point for most apps</p>
		</div>
	</div>
	<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
		{essentialItems.map((item) => <PlaygroundModuleCard item={item} />)}
	</div>
</section>

{
	extendedGroups.map((group) => (
		<section aria-labelledby={`group-${group.id}`} class="mb-10 last:mb-0">
			<div class="mb-4">
				<h2 id={`group-${group.id}`} class="text-lg font-semibold text-balance">
					{group.label}
				</h2>
				<p class="text-sm text-muted-foreground">
					{group.items.length} {group.items.length === 1 ? "module" : "modules"}
				</p>
			</div>
			<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
				{group.items.map((item) => (
					<PlaygroundModuleCard item={item} />
				))}
			</div>
		</section>
	))
}

<footer class="mt-10 border-t border-border pt-6 text-xs text-muted-foreground">
	<p>
		<a href="/getting-started/" class="font-medium text-primary underline-offset-4 hover:underline">
			Getting started
		</a>
		<span aria-hidden="true"> · </span>
		<a href="/core/" class="font-medium text-primary underline-offset-4 hover:underline">Core registry</a>
		<span aria-hidden="true"> · </span>
		<a
			href="https://github.com/ailuracode/alpinejs-toolkit"
			target="_blank"
			rel="noreferrer"
			class="font-medium text-primary underline-offset-4 hover:underline"
		>
			GitHub
			<span class="sr-only"> (opens in new tab)</span>
		</a>
	</p>
</footer>
