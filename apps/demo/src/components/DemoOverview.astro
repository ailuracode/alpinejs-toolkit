---
import {
  getPlaygroundCategoryGroups,
  getPlaygroundDemoCount,
  playgroundCategoryPath,
  playgroundFamilyPath,
} from "../catalog/playground-navigation.js";
import PlaygroundModuleCard from "./PlaygroundModuleCard.astro";

const groups = getPlaygroundCategoryGroups();
const demoCount = getPlaygroundDemoCount();
---

<header class="mb-8 scroll-mt-20 gradient-mesh rounded-[var(--ios-radius-xl)] p-6 -mx-6 fade-in-up">
  <p class="text-sm font-semibold tracking-wide text-[var(--ios-blue)]">Interactive demos</p>
  <h1 class="mt-1 text-4xl font-bold tracking-tight text-balance">Playground</h1>
  <p class="mt-2 max-w-2xl text-sm leading-relaxed text-[var(--ios-label-secondary)] text-pretty">
    Explore Alpine Toolkit packages by functional category and composed families. Each package demo
    remains directly addressable from its family or category page.
  </p>
  <dl class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3">
    <div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20">
      <dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Categories</dt>
      <dd class="mt-1 text-xl font-bold tabular-nums">{groups.length}</dd>
    </div>
    <div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20">
      <dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Package demos</dt>
      <dd class="mt-1 text-xl font-bold tabular-nums">{demoCount}</dd>
    </div>
    <div class="card-hover rounded-[var(--ios-radius-lg)] bg-[var(--ios-bg-secondary)] px-4 py-3 shadow-sm shadow-black/5 dark:shadow-black/20">
      <dt class="text-[10px] font-semibold uppercase tracking-wider text-[var(--ios-label-tertiary)]">Stack</dt>
      <dd class="mt-1 text-sm font-bold leading-tight">Alpine · Astro</dd>
    </div>
  </dl>
</header>

{
  groups.map((group) => (
    <section aria-labelledby={`playground-${group.id}`} class="mb-10 last:mb-0">
      <div class="mb-4 flex items-end justify-between gap-3 fade-in-up">
        <div>
          <h2 id={`playground-${group.id}`} class="text-xl font-bold tracking-tight text-balance">
            <a href={playgroundCategoryPath(group.id)} class="hover:text-[var(--ios-blue)]">
              {group.title}
            </a>
          </h2>
          <p class="text-sm text-[var(--ios-label-secondary)]">{group.summary}</p>
        </div>
      </div>

      {group.families.map((family) => (
        <div class="mb-6">
          <div class="mb-3 flex items-center justify-between gap-3">
            <div>
              <h3 class="text-lg font-semibold">
                <a href={playgroundFamilyPath(group.id, family.id)} class="hover:text-[var(--ios-blue)]">
                  {family.title}
                </a>
              </h3>
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {family.entries.map((entry) => (
              <PlaygroundModuleCard item={{
                id: entry.id,
                title: entry.title,
                package: entry.npmPackage,
                api: entry.api,
                kind: entry.surface,
                tier: entry.tier,
                description: entry.summary,
              }} />
            ))}
          </div>
        </div>
      ))}

      {group.standalone.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {group.standalone.map((entry) => (
            <PlaygroundModuleCard item={{
              id: entry.id,
              title: entry.title,
              package: entry.npmPackage,
              api: entry.api,
              kind: entry.surface,
              tier: entry.tier,
              description: entry.summary,
            }} />
          ))}
        </div>
      ) : null}
    </section>
  ))
}

<footer class="mt-10 border-t border-[var(--ios-separator)] pt-6 text-xs text-[var(--ios-label-secondary)]">
  <p>
    <a href="/packages/" class="font-semibold text-[var(--ios-blue)] underline-offset-4 hover:underline">
      Package catalog
    </a>
    <span aria-hidden="true"> · </span>
    <a href="/getting-started/" class="font-semibold text-[var(--ios-blue)] underline-offset-4 hover:underline">
      Getting started
    </a>
  </p>
</footer>
