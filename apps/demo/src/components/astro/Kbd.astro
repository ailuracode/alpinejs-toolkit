---
import { cn } from "@/lib/utils";

const { class: className, ...rest } = Astro.props;
---

<kbd
	class={cn(
		"pointer-events-none inline-flex h-5 w-fit min-w-5 items-center justify-center gap-1 rounded-[var(--ios-radius-sm)] bg-[var(--ios-fill-tertiary)] px-1.5 font-sans text-[10px] font-semibold tracking-wide text-[var(--ios-label-secondary)] select-none",
		className,
	)}
	{...rest}
>
	<slot />
</kbd>
