---
/**
 * Playground demo actions ‚Äî single DOM layer for Alpine (`@click`, `x-show`, ‚Ä¶).
 * Default: outline + sm. No `ghost` (invisible on dark backgrounds).
 */
import type { VariantProps } from "class-variance-authority";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";

type DemoButtonVariant = "outline" | "default" | "destructive" | "secondary";

type Props = Omit<VariantProps<typeof buttonVariants>, "variant"> & {
  variant?: DemoButtonVariant;
  class?: string;
  href?: string;
  type?: "button" | "submit" | "reset";
};

const {
  variant = "outline",
  size = "sm",
  class: className,
  type = "button",
  href,
  ...rest
} = Astro.props as Props;

const classes = cn(buttonVariants({ variant, size }), className);
---

{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
