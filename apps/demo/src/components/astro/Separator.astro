---
import { cn } from "@/lib/utils";

const { class: className, orientation = "horizontal", ...rest } = Astro.props;
const isVertical = orientation === "vertical";
---

<div
	role="separator"
	aria-orientation={orientation}
	class={cn(
		"shrink-0 bg-border",
		isVertical ? "w-px self-stretch" : "h-px w-full",
		className,
	)}
	{...rest}
/>
