---
import PlaygroundPageHeader from "../../components/PlaygroundPageHeader.astro";
import PlaygroundLayout from "../../layouts/PlaygroundLayout.astro";
import { getPlaygroundDemo } from "../../demo/playground-demos";
import { getPluginNavItem, PLUGIN_NAV_ITEMS } from "../../plugin-nav";

export function getStaticPaths() {
  return PLUGIN_NAV_ITEMS.map((item) => ({
    params: { plugin: item.id },
    props: { pluginId: item.id },
  }));
}

const { pluginId } = Astro.props;
const item = getPluginNavItem(pluginId);
const Demo = getPlaygroundDemo(pluginId);

if (!item || !Demo) {
  throw new Error(`Missing playground demo for plugin: ${pluginId}`);
}
---

<PlaygroundLayout
	title={`${item.title} · Playground`}
	description={item.description}
	activePlugin={pluginId}
>
	<PlaygroundPageHeader item={item} />
	<Demo />
</PlaygroundLayout>
